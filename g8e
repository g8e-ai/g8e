#!/usr/bin/env bash
set -e

# Check for common dependencies
_check_deps() {
    local missing=()
    for cmd in docker curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    # Check for docker-compose-plugin (preferred) or docker-compose (v1)
    if ! docker compose version >/dev/null 2>&1 && ! command -v docker-compose >/dev/null 2>&1; then
        missing+=("docker-compose")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "\033[0;31m[g8e] ERROR: Missing required dependencies: ${missing[*]}\033[0m" >&2
        case "$(uname -s)" in
            Linux)
                if command -v apt-get >/dev/null 2>&1; then
                    echo "  Install via: sudo apt-get update && sudo apt-get install -y docker.io docker-compose-v2 curl"
                elif command -v dnf >/dev/null 2>&1; then
                    echo "  Install via: sudo dnf install docker docker-compose-plugin curl"
                elif command -v pacman >/dev/null 2>&1; then
                    echo "  Install via: sudo pacman -S docker docker-compose curl"
                elif command -v apk >/dev/null 2>&1; then
                    echo "  Install via: sudo apk add docker docker-compose curl"
                fi
                ;;
        esac
        exit 1
    fi
}

_check_deps

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE="docker compose -f $SCRIPT_DIR/docker-compose.yml"
CONTAINER="g8ep"
DEV_MODE=false

# Local credential store (like AWS ~/.aws/credentials or gcloud ~/.config/gcloud)
G8E_CREDENTIALS_DIR="$HOME/.g8e"
G8E_CREDENTIALS_FILE="$G8E_CREDENTIALS_DIR/credentials"

# Test-runner container names
TR_G8EE="g8ee-test-runner"
TR_G8ED="g8ed-test-runner"
TR_G8EO="g8eo-test-runner"

_banner() {
    echo -e "\033[1;34m[g8e]\033[0m $*"
}

_container_running() {
    docker ps --filter "name=^${1}$" --filter "status=running" --format "{{.Names}}" 2>/dev/null | grep -q "^${1}$"
}

_container_exists() {
    docker ps -a --filter "name=^${1}$" --format "{{.Names}}" 2>/dev/null | grep -q "^${1}$"
}

_g8ep_running() { _container_running "$CONTAINER"; }
_g8ep_exists() { _container_exists "$CONTAINER"; }

_ensure_container() {
    local name="$1" cmd="${2:-}"
    if ! _container_running "$name"; then
        if ! _container_exists "$name"; then
            [[ -n "$cmd" ]] && echo "[g8e] Running: ./g8e $cmd"
            echo "[g8e] ${name} is not built — building image (requires Docker)..."
            echo ""
            $COMPOSE build "$name"
            echo ""
        fi
        $COMPOSE up -d --wait "$name"
    fi
}

_ensure_g8ep() { _ensure_container "$CONTAINER" "${1:-}"; }

_exec_in_pod() {
    _ensure_g8ep "$TOP${SUB:+ $SUB}"
    local env_args=()
    if [[ -n "$OPERATOR_SESSION_ID" ]]; then
        env_args=(-e "OPERATOR_SESSION_ID=$OPERATOR_SESSION_ID")
    fi
    if [ -t 0 ] && [ -t 1 ]; then
        exec docker exec -it "${env_args[@]}" "$CONTAINER" "$@"
    else
        exec docker exec -i "${env_args[@]}" "$CONTAINER" "$@"
    fi
}

_test_runner_for() {
    case "$1" in
        g8ee) echo "$TR_G8EE" ;;
        g8ed) echo "$TR_G8ED" ;;
        g8eo) echo "$TR_G8EO" ;;
        *)    echo "" ;;
    esac
}

_exec_in_test_runner() {
    local runner="$1"; shift
    local env_args=()
    if [[ -n "$OPERATOR_SESSION_ID" ]]; then
        env_args=(-e "OPERATOR_SESSION_ID=$OPERATOR_SESSION_ID")
    fi
    if [ -t 0 ] && [ -t 1 ]; then
        exec $COMPOSE run --rm ${env_args[@]+"${env_args[@]}"} -it "$runner" "$@
    else
        exec $COMPOSE run --rm ${env_args[@]+"${env_args[@]}"} "$runner" "$@
    fi
}

# --- Credential Store Functions ---

_load_credentials() {
    if [[ -f "$G8E_CREDENTIALS_FILE" ]]; then
        source "$G8E_CREDENTIALS_FILE"

        # Validate the session if platform is running
        if _g8ep_running && [[ -n "$OPERATOR_SESSION_ID" ]]; then
            if ! _validate_session "$OPERATOR_SESSION_ID"; then
                echo "[g8e] Session expired or invalid. Please re-authenticate." >&2
                _clear_credentials
                return 1
            fi
        fi

        return 0
    fi
    return 1
}

_save_credentials() {
    local operator_session_id="$1"
    local user_id="$2"
    local operator_id="$3"

    mkdir -p "$G8E_CREDENTIALS_DIR"
    cat > "$G8E_CREDENTIALS_FILE" <<EOF
export OPERATOR_SESSION_ID="$operator_session_id"
export USER_ID="$user_id"
export OPERATOR_ID="$operator_id"
export G8E_AUTH_TIMESTAMP="$(date +%s)"
EOF
    chmod 600 "$G8E_CREDENTIALS_FILE"
}

_clear_credentials() {
    if [[ -f "$G8E_CREDENTIALS_FILE" ]]; then
        rm -f "$G8E_CREDENTIALS_FILE"
    fi
    unset OPERATOR_SESSION_ID USER_ID OPERATOR_ID G8E_AUTH_TIMESTAMP
}

_credentials_exist() {
    [[ -f "$G8E_CREDENTIALS_FILE" ]]
}

_validate_session() {
    local operator_session_id="$1"

    # The /api/auth/operator/validate endpoint authenticates via the session id
    # itself (no internal auth token required). Use -k to accept the g8ed
    # self-signed cert; drop -f so we can distinguish empty (network error)
    # from a JSON error body.
    local validate_url="https://localhost/api/auth/operator/validate"
    local response

    response=$(docker exec -i g8ed \
        curl -sk -X POST \
        -H 'Content-Type: application/json' \
        -d "{\"operator_session_id\":\"$operator_session_id\"}" \
        "$validate_url" 2>/dev/null || true)

    if [[ -z "$response" ]]; then
        return 1
    fi

    if echo "$response" | grep -q '"valid":true'; then
        return 0
    else
        return 1
    fi
}


_help() {
    local help_file="$SCRIPT_DIR/docs/g8e-help.md"
    if [[ -f "$help_file" ]]; then
        cat "$help_file"
    else
        echo "[g8e] Help file not found: $help_file" >&2
        exit 1
    fi
}

if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    _help
    exit 0
fi

# Save original arguments for login command
ORIGINAL_ARGS=("$@")

# Parse global authentication flags from all arguments
API_KEY=""
DEVICE_TOKEN=""
filtered_args=()
i=1
while [[ $i -le $# ]]; do
    arg="${!i}"
    case "$arg" in
        --api-key|-k)
            if [[ $i -lt $# ]]; then
                ((i++))
                API_KEY="${!i}"
            fi
            ((i++))
            ;;
        --device-token)
            if [[ $i -lt $# ]]; then
                ((i++))
                DEVICE_TOKEN="${!i}"
            fi
            ((i++))
            ;;
        --dev)
            DEV_MODE=true
            ((i++))
            ;;
        -*)
            # Preserve other flags that might appear before subcommand
            filtered_args+=("$arg")
            ((i++))
            ;;
        *)
            # First non-flag argument is the subcommand. Stop parsing global flags.
            while [[ $i -le $# ]]; do
                filtered_args+=("${!i}")
                ((i++))
            done
            break
            ;;
    esac
done

# Reset positional parameters with filtered arguments (without auth flags)
set -- "${filtered_args[@]}"

TOP="$1"
SUB="${2:-}"

# User authentication - authenticate via API key or device link token
OPERATOR_SESSION_ID=""
USER_ID=""
OPERATOR_ID=""

_ensure_authenticated() {
    # First, try loading from local credential store
    if _load_credentials; then
        export OPERATOR_SESSION_ID USER_ID OPERATOR_ID
        return 0
    fi

    # Set default session values
    export OPERATOR_SESSION_ID="default-session-id"
    export USER_ID="default-user-id"
    export OPERATOR_ID="default-operator-id"
    return 0
}

# Commands that require authentication
# Note: operator deploy/stream need auth, but other operator subcommands don't
# security, data, mcp commands need auth for g8ed internal API access
# Skip auth for 'test' command when running in CI (trusted environment)
AUTH_REQUIRED_COMMANDS=("test" "security" "data" "mcp")
if [[ " ${AUTH_REQUIRED_COMMANDS[@]} " =~ " ${TOP} " ]]; then
    if [[ "$TOP" == "test" && "${CI:-}" == "true" ]]; then
        echo "[g8e] Running in CI mode - skipping authentication for tests"
    else
        _ensure_authenticated
    fi
fi

# Special case: operator deploy, stream, and reauth need auth
# platform settings needs auth for g8ed internal API access
if [[ "$TOP" == "operator" && ("$SUB" == "deploy" || "$SUB" == "stream" || "$SUB" == "reauth") ]]; then
    _ensure_authenticated
fi

if [[ "$TOP" == "platform" && "$SUB" == "settings" ]]; then
    _ensure_authenticated
fi

case "$TOP" in

    # ------------------------------------------------------------------
    # login — authenticate and save session locally
    # ------------------------------------------------------------------
    login)
        _banner "login"
        export OPERATOR_SESSION_ID="default-session-id"
        export USER_ID="default-user-id"
        export OPERATOR_ID="default-operator-id"
        _save_credentials "$OPERATOR_SESSION_ID" "$USER_ID" "$OPERATOR_ID"
        echo "[g8e] Session saved to $G8E_CREDENTIALS_FILE"
        exit 0 ;;

    # ------------------------------------------------------------------
    # logout — clear local session
    # ------------------------------------------------------------------
    logout)
        _banner "logout"
        if _credentials_exist; then
            _clear_credentials
            echo "[g8e] Session cleared from $G8E_CREDENTIALS_FILE"
        else
            echo "[g8e] No active session found"
        fi
        exit 0 ;;

    # ------------------------------------------------------------------
    # platform — manages Docker services; must run on host
    # ------------------------------------------------------------------
    platform)
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### platform/,/^### operator/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            setup)
                _banner "platform setup"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" setup ;;
            build)
                _banner "platform build"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" rebuild "${@:3}" ;;
            settings)
                _banner "platform settings"
                _exec_in_pod python3 /app/scripts/data/manage-g8es.py settings show "${@:3}" ;;
            update)
                _banner "platform update"
                git -C "$SCRIPT_DIR" fetch origin main 2>&1 | sed 's/^/  /'
                _local=$(git -C "$SCRIPT_DIR" rev-parse HEAD)
                _remote=$(git -C "$SCRIPT_DIR" rev-parse origin/main 2>/dev/null || echo "unknown")
                if [[ "$_local" == "$_remote" ]]; then
                    echo "  Already up to date ($(git -C "$SCRIPT_DIR" rev-parse --short HEAD))."
                    echo ""
                    echo "  Nothing to pull — run './g8e platform rebuild' to force a rebuild."
                    exit 0
                fi
                echo ""
                echo "  Local:  $(git -C "$SCRIPT_DIR" rev-parse --short HEAD)  ($(git -C "$SCRIPT_DIR" log -1 --format='%s' HEAD))"
                echo "  Remote: $(git -C "$SCRIPT_DIR" rev-parse --short origin/main)  ($(git -C "$SCRIPT_DIR" log -1 --format='%s' origin/main))"
                echo ""
                git -C "$SCRIPT_DIR" log --oneline HEAD..origin/main | sed 's/^/  + /'
                echo ""
                printf "  Pull and rebuild? [y/N] "
                read -r _confirm
                if [[ "$_confirm" != "y" && "$_confirm" != "Y" ]]; then
                    echo "  Aborted."
                    exit 0
                fi
                git -C "$SCRIPT_DIR" pull origin main
                echo ""
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" rebuild ;;
            logs)
                _banner "platform logs"
                exec bash "$SCRIPT_DIR/scripts/core/logs.sh" "${@:3}" ;;
            status|start|stop|restart|rebuild|reset|wipe|clean)
                case "$SUB" in
                    start)   _banner "platform start";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" $([[ "$DEV_MODE" == true ]] && echo "--dev") up      "${@:3}" ;;
                    stop)    _banner "platform stop";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" down    "${@:3}" ;;
                    restart) _banner "platform restart"; exec bash "$SCRIPT_DIR/scripts/core/build.sh" $([[ "$DEV_MODE" == true ]] && echo "--dev") restart "${@:3}" ;;
                    status)  _banner "platform status";  exec bash "$SCRIPT_DIR/scripts/core/build.sh" status  "${@:3}" ;;
                    rebuild) _banner "platform rebuild"; exec bash "$SCRIPT_DIR/scripts/core/build.sh" $([[ "$DEV_MODE" == true ]] && echo "--dev") rebuild "${@:3}" ;;
                    reset)   _banner "platform reset";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" reset   "${@:3}" ;;
                    wipe)    _banner "platform wipe";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" wipe    "${@:3}" ;;
                    clean)   _banner "platform clean";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" clean   "${@:3}" ;;
                esac ;;
            *)
                echo "[g8e] unknown platform subcommand: '$SUB'" >&2
                echo "  Valid: setup, build, settings, update, status, start, stop, rebuild, reset, wipe, clean, logs" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # operator — build/deploy must run on host; test runs in g8ep
    # ------------------------------------------------------------------
    operator)
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### operator/,/^### test/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            reauth)
                _banner "operator reauth"
                _ensure_g8ep "operator reauth"

                USER_ID=""
                EMAIL=""
                while [[ $# -gt 2 ]]; do
                    case "${3:-}" in
                        --user-id) USER_ID="${4:-}"; shift 2 ;;
                        --email)   EMAIL="${4:-}"; shift 2 ;;
                        *) echo "[g8e] unknown option: '${3}'"; echo "  Usage: ./g8e operator reauth --user-id <id>"; echo "         ./g8e operator reauth --email <email>"; exit 1 ;;
                    esac
                done

                if [[ -z "$USER_ID" && -z "$EMAIL" ]]; then
                    echo "[g8e] operator reauth requires --user-id <id> or --email <email>" >&2
                    echo "  Usage: ./g8e operator reauth --user-id <id>" >&2
                    echo "         ./g8e operator reauth --email <email>" >&2
                    exit 1
                fi

                if [[ -n "$EMAIL" && -z "$USER_ID" ]]; then
                    USER_ID="$(docker exec -i "$CONTAINER" \
                        python3 /app/scripts/data/manage-g8es.py users get --email "$EMAIL" 2>/dev/null \
                        | grep -E '^  ID:' | awk '{print $2}')"
                    if [[ -z "$USER_ID" ]]; then
                        echo "[g8e] No user found with email: $EMAIL" >&2
                        exit 1
                    fi
                fi

                RESPONSE="$(docker exec -i g8ed \
                    curl -sf -X POST \
                    -H 'Content-Type: application/json' \
                    -H "x-operator-session-id: $OPERATOR_SESSION_ID" \
                    "https://localhost/api/internal/operators/user/$USER_ID/reauth")"
                EXIT_CODE=$?

                if [[ $EXIT_CODE -ne 0 ]]; then
                    echo "[g8e] Reauth request failed" >&2
                    exit 1
                fi

                echo "$RESPONSE" | grep -q '"success":true' \
                    && echo "[g8e] g8ep operator relaunched for user $USER_ID" \
                    || { echo "[g8e] Reauth failed: $RESPONSE" >&2; exit 1; }
                exit 0 ;;

            init)
                _banner "operator init"
                _version="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo 'v0.0.0')"
                $COMPOSE run --rm "$TR_G8EO" bash -c "
                    set -e
                    cd /app/components/g8eo
                    mkdir -p certs
                    [ -f /g8es/ssl/ca.crt ] && cp /g8es/ssl/ca.crt certs/server_ca.crt
                    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \\
                        -trimpath -buildvcs=false \\
                        -ldflags \"-s -w -X main.version=${_version} -X 'main.platform=linux/amd64'\" \\
                        -o /home/g8e/g8e.operator .
                    echo '[g8eo-test-runner] Built: /home/g8e/g8e.operator'
                "
                echo ""
                echo "Operator binary built."
                exit 0 ;;
            build)
                _banner "operator build"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build ;;
            build-all)
                _banner "operator build-all"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build-all ;;
            deploy)
                _banner "operator deploy ${@:3}"
                _DEPLOY_TARGET=""
                _DEPLOY_ARCH="amd64"
                _DEPLOY_DEST="./g8e.operator"
                _DEPLOY_ENDPOINT=""
                _DEPLOY_DEVICE_TOKEN=""
                _DEPLOY_API_KEY=""
                _DEPLOY_NO_GIT=false
                _DEPLOY_WSS_PORT=""
                _DEPLOY_HTTP_PORT=""
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch)         _DEPLOY_ARCH="$2";         shift 2 ;;
                        --dest)         _DEPLOY_DEST="$2";         shift 2 ;;
                        --endpoint)     _DEPLOY_ENDPOINT="$2";     shift 2 ;;
                        --device-token) _DEPLOY_DEVICE_TOKEN="$2"; shift 2 ;;
                        --key)          _DEPLOY_API_KEY="$2";      shift 2 ;;
                        --wss-port)     _DEPLOY_WSS_PORT="$2";     shift 2 ;;
                        --http-port)    _DEPLOY_HTTP_PORT="$2";    shift 2 ;;
                        --no-git)       _DEPLOY_NO_GIT=true;        shift ;;
                        -h|--help)
                            echo "Usage: ./g8e operator deploy <user@host> [options]"
                            echo "  --arch amd64|arm64|386       (default: amd64)"
                            echo "  --dest /path                 (default: ./g8e.operator)"
                            echo "  --endpoint <host>            Platform endpoint"
                            echo "  --device-token <tok>         Device link token"
                            echo "  --key <apikey>               API key auth (fallback)"
                            echo "  --wss-port <port>            WSS port for pub/sub (default: 443)"
                            echo "  --http-port <port>           HTTPS port for auth (default: 443)"
                            echo "  --no-git                     Disable ledger"
                            exit 0 ;;
                        *) _DEPLOY_TARGET="$1"; shift ;;
                    esac
                done
                if [[ -z "$_DEPLOY_TARGET" ]]; then
                    echo "[g8e] operator deploy requires a target host" >&2
                    echo "  Usage: ./g8e operator deploy <user@host> [options]" >&2
                    exit 1
                fi
                _ensure_g8ep "operator deploy"
                _REMOTE_EXEC="${_DEPLOY_DEST}"
                [[ "$(basename "${_DEPLOY_DEST}")" != "g8e.operator" ]] && _REMOTE_EXEC="${_DEPLOY_DEST%/}/g8e.operator"
                echo "Fetching linux/${_DEPLOY_ARCH} operator from g8es blob store and copying to ${_DEPLOY_TARGET}:${_DEPLOY_DEST}..."
                docker exec -i g8ep curl -sf \
                    -H "X-Operator-Session-Id: ${OPERATOR_SESSION_ID}" \
                    --cacert /g8es/ca.crt \
                    "https://g8es:9000/blob/operator-binary/linux-${_DEPLOY_ARCH}" \
                    | ssh "${_DEPLOY_TARGET}" "cat > ${_DEPLOY_DEST} && chmod +x ${_DEPLOY_DEST}"
                echo "  Done."
                if [[ -n "$_DEPLOY_ENDPOINT" ]]; then
                    _REMOTE_CMD="nohup ${_REMOTE_EXEC} -e ${_DEPLOY_ENDPOINT}"
                    [[ -n "$_DEPLOY_DEVICE_TOKEN" ]] && _REMOTE_CMD+=" -D ${_DEPLOY_DEVICE_TOKEN}"
                    [[ -n "$_DEPLOY_API_KEY" ]]      && _REMOTE_CMD+=" -k ${_DEPLOY_API_KEY}"
                    [[ -n "$_DEPLOY_WSS_PORT" ]]     && _REMOTE_CMD+=" --wss-port ${_DEPLOY_WSS_PORT}"
                    [[ -n "$_DEPLOY_HTTP_PORT" ]]    && _REMOTE_CMD+=" --http-port ${_DEPLOY_HTTP_PORT}"
                    [[ "$_DEPLOY_NO_GIT" == "true" ]] && _REMOTE_CMD+=" --no-git"
                    _REMOTE_CMD+=" > ./g8e.operator.log 2>&1 &"
                    echo "Starting operator on ${_DEPLOY_TARGET}..."
                    ssh "${_DEPLOY_TARGET}" "${_REMOTE_CMD}"
                    echo "  Operator started. Logs: ./g8e.operator.log"
                fi
                exit 0 ;;
            stream)
                if [[ "${3:-}" == "-h" || "${3:-}" == "--help" || "${3:-}" == "" ]]; then
                    _ensure_g8ep "operator stream"
                    if [ -t 0 ] && [ -t 1 ]; then
                        exec docker exec -it "$CONTAINER" /home/g8e/g8e.operator stream --help
                    else
                        exec docker exec -i "$CONTAINER" /home/g8e/g8e.operator stream --help
                    fi
                fi
                _banner "operator stream ${@:3}"
                _ensure_g8ep "operator stream"
                if ! docker exec "$CONTAINER" test -f /home/g8e/g8e.operator 2>/dev/null; then
                    echo "[g8e] Operator binary not found in g8ep at /home/g8e/g8e.operator" >&2
                    echo "  Run: ./g8e operator build" >&2
                    exit 1
                fi
                _stream_args=(/home/g8e/g8e.operator stream)
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch|--hosts|--concurrency|--timeout|--endpoint|--device-token|--key|--ssh-config)
                            _stream_args+=("$1" "$2"); shift 2 ;;
                        --no-git) _stream_args+=("--no-git"); shift ;;
                        *) _stream_args+=("$1"); shift ;;
                    esac
                done
                if [ -t 0 ] && [ -t 1 ]; then
                    exec docker exec -it "$CONTAINER" "${_stream_args[@]}"
                else
                    exec docker exec -i "$CONTAINER" "${_stream_args[@]}"
                fi ;;
            ssh-config)
                _banner "operator ssh-config"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-ssh.sh" ssh-config "${@:3}" ;;
            *)
                echo "[g8e] unknown operator subcommand: '$SUB'" >&2
                echo "  Valid: deploy, stream, ssh-config, reauth, build-all" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # test — routes to per-component test-runner containers
    # ------------------------------------------------------------------
    test)
        _banner "model parity check"
        python3 "$SCRIPT_DIR/scripts/testing/check_model_parity.py" || exit 1

        _TEST_COMPONENT="${2:-}"
        if [[ -z "$_TEST_COMPONENT" || "$_TEST_COMPONENT" == "-h" || "$_TEST_COMPONENT" == "--help" ]]; then
            help_file="$SCRIPT_DIR/docs/g8e-help.md"
            if [[ -f "$help_file" ]]; then
                awk '/^### test/,/^### security/' "$help_file" | head -n -1
            else
                echo "[g8e] Help file not found: $help_file" >&2
                exit 1
            fi
            [[ -z "$_TEST_COMPONENT" ]] && exit 1 || exit 0
        fi
        _TEST_RUNNER="$(_test_runner_for "$_TEST_COMPONENT")"
        if [[ -z "$_TEST_RUNNER" ]]; then
            echo "[g8e] Unknown test component: '$_TEST_COMPONENT'" >&2
            echo "  Valid: g8ee, g8ed, g8eo" >&2
            exit 1
        fi

        _TEST_ENV_ARGS=()
        _TEST_PASSTHROUGH=()
        _args=("${@:3}")
        _require_value() {
            # $1: flag name for error message; reads _args from outer scope
            if [[ ${#_args[@]} -lt 2 || "${_args[1]}" == -* || "${_args[1]}" == "--" ]]; then
                echo "[g8e] $1 requires a value" >&2
                exit 1
            fi
        }
        while [[ ${#_args[@]} -gt 0 ]]; do
            case "${_args[0]}" in
                -p|--llm-provider)
                    _require_value "-p/--llm-provider"
                    export TEST_LLM_PROVIDER="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -m|--primary-model)
                    _require_value "-m/--primary-model"
