#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE="docker compose -f $SCRIPT_DIR/docker-compose.yml"
CONTAINER="g8ep"

# Test-runner container names
TR_G8EE="g8ee-test-runner"
TR_G8ED="g8ed-test-runner"
TR_G8EO="g8eo-test-runner"

_banner() {
    echo -e "\033[1;34m[g8e]\033[0m $*"
}

_container_running() {
    docker ps --filter "name=^${1}$" --filter "status=running" -q 2>/dev/null | grep -q .
}

_container_exists() {
    docker ps -a --filter "name=^${1}$" -q 2>/dev/null | grep -q .
}

_g8ep_running() { _container_running "$CONTAINER"; }
_g8ep_exists() { _container_exists "$CONTAINER"; }

_ensure_container() {
    local name="$1" cmd="${2:-}"
    if ! _container_running "$name"; then
        if ! _container_exists "$name"; then
            [[ -n "$cmd" ]] && echo "[g8e] Running: ./g8e $cmd"
            echo "[g8e] ${name} is not built — building image (requires Docker)..."
            echo ""
            $COMPOSE build "$name"
            echo ""
        fi
        $COMPOSE up -d --wait "$name"
    fi
}

_ensure_g8ep() { _ensure_container "$CONTAINER" "${1:-}"; }

_exec_in_pod() {
    _ensure_g8ep "$TOP${SUB:+ $SUB}"
    if [ -t 0 ] && [ -t 1 ]; then
        exec docker exec -it "$CONTAINER" "$@"
    else
        exec docker exec -i "$CONTAINER" "$@"
    fi
}

_test_runner_for() {
    case "$1" in
        g8ee) echo "$TR_G8EE" ;;
        g8ed) echo "$TR_G8ED" ;;
        g8eo) echo "$TR_G8EO" ;;
        *)    echo "" ;;
    esac
}

_exec_in_test_runner() {
    local runner="$1"; shift
    _ensure_container "$runner" "$TOP${SUB:+ $SUB}"
    if [ -t 0 ] && [ -t 1 ]; then
        exec docker exec -it "$runner" "$@"
    else
        exec docker exec -i "$runner" "$@"
    fi
}


_help() {
    local help_file="$SCRIPT_DIR/docs/g8e-help.md"
    if [[ -f "$help_file" ]]; then
        cat "$help_file"
    else
        echo "[g8e] Help file not found: $help_file" >&2
        exit 1
    fi
}

if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    _help
    exit 0
fi

TOP="$1"
SUB="${2:-}"

# --- Authentication ---
# Pull the internal auth token into memory as a constant for the duration of the run.
# This ensures that all subcommands have access to the token for internal API calls.
INTERNAL_AUTH_TOKEN=""
if [[ "$TOP" != "platform" || ("$SUB" != "start" && "$SUB" != "status" && "$SUB" != "stop" && "$SUB" != "restart" && "$SUB" != "rebuild" && "$SUB" != "reset" && "$SUB" != "wipe" && "$SUB" != "clean") ]]; then
    if _g8ep_running; then
        # Use docker exec to read the token directly from the SSL volume mount in g8ep
        INTERNAL_AUTH_TOKEN=$(docker exec -i "$CONTAINER" cat /g8es/internal_auth_token 2>/dev/null || true)
    fi
fi
readonly INTERNAL_AUTH_TOKEN

case "$TOP" in

    # ------------------------------------------------------------------
    # platform — manages Docker services; must run on host
    # ------------------------------------------------------------------
    platform)
        case "$SUB" in
            setup)
                _banner "platform setup"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" setup ;;
            build)
                _banner "platform build"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" rebuild ;;
            settings)
                _banner "platform settings"
                _exec_in_pod python3 /app/scripts/data/manage-g8es.py settings show "${@:3}" ;;
            update)
                _banner "platform update"
                git -C "$SCRIPT_DIR" fetch origin main 2>&1 | sed 's/^/  /'
                _local=$(git -C "$SCRIPT_DIR" rev-parse HEAD)
                _remote=$(git -C "$SCRIPT_DIR" rev-parse origin/main 2>/dev/null || echo "unknown")
                if [[ "$_local" == "$_remote" ]]; then
                    echo "  Already up to date ($(git -C "$SCRIPT_DIR" rev-parse --short HEAD))."
                    echo ""
                    echo "  Nothing to pull — run './g8e platform rebuild' to force a rebuild."
                    exit 0
                fi
                echo ""
                echo "  Local:  $(git -C "$SCRIPT_DIR" rev-parse --short HEAD)  ($(git -C "$SCRIPT_DIR" log -1 --format='%s' HEAD))"
                echo "  Remote: $(git -C "$SCRIPT_DIR" rev-parse --short origin/main)  ($(git -C "$SCRIPT_DIR" log -1 --format='%s' origin/main))"
                echo ""
                git -C "$SCRIPT_DIR" log --oneline HEAD..origin/main | sed 's/^/  + /'
                echo ""
                printf "  Pull and rebuild? [y/N] "
                read -r _confirm
                if [[ "$_confirm" != "y" && "$_confirm" != "Y" ]]; then
                    echo "  Aborted."
                    exit 0
                fi
                git -C "$SCRIPT_DIR" pull origin main
                echo ""
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" rebuild ;;
            logs)
                _banner "platform logs"
                exec bash "$SCRIPT_DIR/scripts/core/logs.sh" "${@:3}" ;;
            status|start|stop|restart|rebuild|reset|wipe|clean)
                case "$SUB" in
                    start)   _banner "platform start";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" up      "${@:3}" ;;
                    stop)    _banner "platform stop";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" down    "${@:3}" ;;
                    restart) _banner "platform restart"; exec bash "$SCRIPT_DIR/scripts/core/build.sh" restart "${@:3}" ;;
                    status)  _banner "platform status";  exec bash "$SCRIPT_DIR/scripts/core/build.sh" status  "${@:3}" ;;
                    rebuild) _banner "platform rebuild"; exec bash "$SCRIPT_DIR/scripts/core/build.sh" rebuild "${@:3}" ;;
                    reset)   _banner "platform reset";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" reset   "${@:3}" ;;
                    wipe)    _banner "platform wipe";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" wipe    "${@:3}" ;;
                    clean)   _banner "platform clean";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" clean   "${@:3}" ;;
                esac ;;
            "")
                echo "[g8e] missing subcommand for 'platform'" >&2
                echo "  Valid: setup, build, settings, update, status, start, stop, rebuild, reset, wipe, clean, logs" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown platform subcommand: '$SUB'" >&2
                echo "  Valid: setup, build, settings, update, status, start, stop, rebuild, reset, wipe, clean, logs" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # operator — build/deploy must run on host; test runs in g8ep
    # ------------------------------------------------------------------
    operator)
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    # Extract only the operator section from the help file
                    awk '/^### operator/,/^### test/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            reauth)
                _banner "operator reauth"
                _ensure_g8ep "operator reauth"

                USER_ID=""
                EMAIL=""
                while [[ $# -gt 2 ]]; do
                    case "${3:-}" in
                        --user-id) USER_ID="${4:-}"; shift 2 ;;
                        --email)   EMAIL="${4:-}"; shift 2 ;;
                        *) echo "[g8e] unknown option: '${3}'"; echo "  Usage: ./g8e operator reauth --user-id <id>"; echo "         ./g8e operator reauth --email <email>"; exit 1 ;;
                    esac
                done

                if [[ -z "$USER_ID" && -z "$EMAIL" ]]; then
                    echo "[g8e] operator reauth requires --user-id <id> or --email <email>" >&2
                    echo "  Usage: ./g8e operator reauth --user-id <id>" >&2
                    echo "         ./g8e operator reauth --email <email>" >&2
                    exit 1
                fi

                if [[ -z "$INTERNAL_AUTH_TOKEN" ]]; then
                    echo "[g8e] Authentication failed: Internal auth token not found." >&2
                    echo "          Ensure the platform is running: ./g8e platform start" >&2
                    exit 1
                fi

                if [[ -n "$EMAIL" && -z "$USER_ID" ]]; then
                    USER_ID="$(docker exec -i "$CONTAINER" \
                        python3 /app/scripts/data/manage-g8es.py users get --email "$EMAIL" 2>/dev/null \
                        | grep -E '^  ID:' | awk '{print $2}')"
                    if [[ -z "$USER_ID" ]]; then
                        echo "[g8e] No user found with email: $EMAIL" >&2
                        exit 1
                    fi
                fi

                RESPONSE="$(docker exec -i g8ed \
                    curl -sf -X POST \
                    -H 'Content-Type: application/json' \
                    -H "x-internal-auth: $INTERNAL_AUTH_TOKEN" \
                    "https://localhost/api/internal/operators/user/$USER_ID/reauth")"
                EXIT_CODE=$?

                if [[ $EXIT_CODE -ne 0 ]]; then
                    echo "[g8e] Reauth request failed" >&2
                    exit 1
                fi

                echo "$RESPONSE" | grep -q '"success":true' \
                    && echo "[g8e] g8ep operator relaunched for user $USER_ID" \
                    || { echo "[g8e] Reauth failed: $RESPONSE" >&2; exit 1; }
                exit 0 ;;

            init)
                _banner "operator init"
                _ensure_container "$TR_G8EO" "operator init"
                _version="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo 'v0.0.0')"
                docker exec "$TR_G8EO" bash -c "
                    set -e
                    cd /app/components/g8eo
                    mkdir -p certs
                    [ -f /g8es/ssl/ca.crt ] && cp /g8es/ssl/ca.crt certs/server_ca.crt
                    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \\
                        -trimpath -buildvcs=false \\
                        -ldflags \"-s -w -X main.version=${_version} -X 'main.platform=linux/amd64'\" \\
                        -o /home/g8e/g8e.operator .
                    echo '[g8eo-test-runner] Built: /home/g8e/g8e.operator'
                "
                echo ""
                echo "Operator binary built."
                exit 0 ;;
            build)
                _banner "operator build"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build ;;
            build-all)
                _banner "operator build-all"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build-all ;;
            deploy)
                _banner "operator deploy ${@:3}"
                _DEPLOY_TARGET=""
                _DEPLOY_ARCH="amd64"
                _DEPLOY_DEST="./g8e.operator"
                _DEPLOY_ENDPOINT=""
                _DEPLOY_DEVICE_TOKEN=""
                _DEPLOY_API_KEY=""
                _DEPLOY_NO_GIT=false
                _DEPLOY_WSS_PORT=""
                _DEPLOY_HTTP_PORT=""
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch)         _DEPLOY_ARCH="$2";         shift 2 ;;
                        --dest)         _DEPLOY_DEST="$2";         shift 2 ;;
                        --endpoint)     _DEPLOY_ENDPOINT="$2";     shift 2 ;;
                        --device-token) _DEPLOY_DEVICE_TOKEN="$2"; shift 2 ;;
                        --key)          _DEPLOY_API_KEY="$2";      shift 2 ;;
                        --wss-port)     _DEPLOY_WSS_PORT="$2";     shift 2 ;;
                        --http-port)    _DEPLOY_HTTP_PORT="$2";    shift 2 ;;
                        --no-git)       _DEPLOY_NO_GIT=true;        shift ;;
                        -h|--help)
                            echo "Usage: ./g8e operator deploy <user@host> [options]"
                            echo "  --arch amd64|arm64|386       (default: amd64)"
                            echo "  --dest /path                 (default: ./g8e.operator)"
                            echo "  --endpoint <host>            Platform endpoint"
                            echo "  --device-token <tok>         Device link token"
                            echo "  --key <apikey>               API key auth (fallback)"
                            echo "  --wss-port <port>            WSS port for pub/sub (default: 443)"
                            echo "  --http-port <port>           HTTPS port for auth (default: 443)"
                            echo "  --no-git                     Disable ledger"
                            exit 0 ;;
                        *) _DEPLOY_TARGET="$1"; shift ;;
                    esac
                done
                if [[ -z "$_DEPLOY_TARGET" ]]; then
                    echo "[g8e] operator deploy requires a target host" >&2
                    echo "  Usage: ./g8e operator deploy <user@host> [options]" >&2
                    exit 1
                fi
                _ensure_g8ep "operator deploy"
                _REMOTE_EXEC="${_DEPLOY_DEST}"
                [[ "$(basename "${_DEPLOY_DEST}")" != "g8e.operator" ]] && _REMOTE_EXEC="${_DEPLOY_DEST%/}/g8e.operator"
                echo "Fetching linux/${_DEPLOY_ARCH} operator from g8es blob store and copying to ${_DEPLOY_TARGET}:${_DEPLOY_DEST}..."
                docker exec -i g8ep curl -sf \
                    -H "X-Internal-Auth: ${INTERNAL_AUTH_TOKEN}" \
                    --cacert /g8es/ca.crt \
                    "https://g8es:9000/blob/operator-binary/linux-${_DEPLOY_ARCH}" \
                    | ssh "${_DEPLOY_TARGET}" "cat > ${_DEPLOY_DEST} && chmod +x ${_DEPLOY_DEST}"
                echo "  Done."
                if [[ -n "$_DEPLOY_ENDPOINT" ]]; then
                    _REMOTE_CMD="nohup ${_REMOTE_EXEC} -e ${_DEPLOY_ENDPOINT}"
                    [[ -n "$_DEPLOY_DEVICE_TOKEN" ]] && _REMOTE_CMD+=" -D ${_DEPLOY_DEVICE_TOKEN}"
                    [[ -n "$_DEPLOY_API_KEY" ]]      && _REMOTE_CMD+=" -k ${_DEPLOY_API_KEY}"
                    [[ -n "$_DEPLOY_WSS_PORT" ]]     && _REMOTE_CMD+=" --wss-port ${_DEPLOY_WSS_PORT}"
                    [[ -n "$_DEPLOY_HTTP_PORT" ]]    && _REMOTE_CMD+=" --http-port ${_DEPLOY_HTTP_PORT}"
                    [[ "$_DEPLOY_NO_GIT" == "true" ]] && _REMOTE_CMD+=" --no-git"
                    _REMOTE_CMD+=" > ./g8e.operator.log 2>&1 &"
                    echo "Starting operator on ${_DEPLOY_TARGET}..."
                    ssh "${_DEPLOY_TARGET}" "${_REMOTE_CMD}"
                    echo "  Operator started. Logs: ./g8e.operator.log"
                fi
                exit 0 ;;
            stream)
                if [[ "${3:-}" == "-h" || "${3:-}" == "--help" || "${3:-}" == "" ]]; then
                    _ensure_g8ep "operator stream"
                    if [ -t 0 ] && [ -t 1 ]; then
                        exec docker exec -it "$CONTAINER" /home/g8e/g8e.operator stream --help
                    else
                        exec docker exec -i "$CONTAINER" /home/g8e/g8e.operator stream --help
                    fi
                fi
                _banner "operator stream ${@:3}"
                _ensure_g8ep "operator stream"
                if ! docker exec "$CONTAINER" test -f /home/g8e/g8e.operator 2>/dev/null; then
                    echo "[g8e] Operator binary not found in g8ep at /home/g8e/g8e.operator" >&2
                    echo "  Run: ./g8e operator build" >&2
                    exit 1
                fi
                _stream_args=(/home/g8e/g8e.operator stream)
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch|--hosts|--concurrency|--timeout|--endpoint|--device-token|--key|--ssh-config)
                            _stream_args+=("$1" "$2"); shift 2 ;;
                        --no-git) _stream_args+=("--no-git"); shift ;;
                        *) _stream_args+=("$1"); shift ;;
                    esac
                done
                if [ -t 0 ] && [ -t 1 ]; then
                    exec docker exec -it "$CONTAINER" "${_stream_args[@]}"
                else
                    exec docker exec -i "$CONTAINER" "${_stream_args[@]}"
                fi ;;
            ssh-config)
                _banner "operator ssh-config"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-ssh.sh" ssh-config "${@:3}" ;;
            *)
                echo "[g8e] unknown operator subcommand: '$SUB'" >&2
                echo "  Valid: deploy, stream, ssh-config, reauth, build-all" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # test — routes to per-component test-runner containers
    # ------------------------------------------------------------------
    test)
        _TEST_COMPONENT="${2:-}"
        if [[ -z "$_TEST_COMPONENT" ]]; then
            echo "[g8e] Usage: ./g8e test <g8ee|g8ed|g8eo> [OPTIONS] [-- EXTRA_ARGS]" >&2
            exit 1
        fi
        _TEST_RUNNER="$(_test_runner_for "$_TEST_COMPONENT")"
        if [[ -z "$_TEST_RUNNER" ]]; then
            echo "[g8e] Unknown test component: '$_TEST_COMPONENT'" >&2
            echo "  Valid: g8ee, g8ed, g8eo" >&2
            exit 1
        fi

        _TEST_ENV_ARGS=()
        _TEST_PASSTHROUGH=()
        _args=("${@:3}")
        _require_value() {
            # $1: flag name for error message; reads _args from outer scope
            if [[ ${#_args[@]} -lt 2 || "${_args[1]}" == -* || "${_args[1]}" == "--" ]]; then
                echo "[g8e] $1 requires a value" >&2
                exit 1
            fi
        }
        while [[ ${#_args[@]} -gt 0 ]]; do
            case "${_args[0]}" in
                -p|--llm-provider)
                    _require_value "-p/--llm-provider"
                    export TEST_LLM_PROVIDER="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -m|--primary-model)
                    _require_value "-m/--primary-model"
                    export TEST_LLM_PRIMARY_MODEL="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -a|--assistant-model)
                    _require_value "-a/--assistant-model"
                    export TEST_LLM_ASSISTANT_MODEL="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -e|--llm-endpoint-url)
                    _require_value "-e/--llm-endpoint-url"
                    export TEST_LLM_ENDPOINT_URL="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -k|--llm-api-key)
                    _require_value "-k/--llm-api-key"
                    export TEST_LLM_API_KEY="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -j|--parallel)
                    # Optional value: accept "auto" or a positive integer; otherwise default to "auto".
                    if [[ ${#_args[@]} -ge 2 && ( "${_args[1]}" == "auto" || "${_args[1]}" =~ ^[0-9]+$ ) ]]; then
                        _TEST_PASSTHROUGH+=("--parallel" "${_args[1]}")
                        _args=("${_args[@]:2}")
                    else
                        _TEST_PASSTHROUGH+=("--parallel" "auto")
                        _args=("${_args[@]:1}")
                    fi ;;
                --)
                    _TEST_PASSTHROUGH+=("${_args[@]}")
                    break ;;
                *)
                    _TEST_PASSTHROUGH+=("${_args[0]}")
                    _args=("${_args[@]:1}") ;;
            esac
        done
        _TEST_PASSTHROUGH=("$_TEST_COMPONENT" "${_TEST_PASSTHROUGH[@]}")

        [[ -n "${TEST_LLM_PROVIDER:-}" ]]              && _TEST_ENV_ARGS+=(-e "TEST_LLM_PROVIDER=$TEST_LLM_PROVIDER")
        [[ -n "${TEST_LLM_ASSISTANT_PROVIDER:-}" ]]     && _TEST_ENV_ARGS+=(-e "TEST_LLM_ASSISTANT_PROVIDER=$TEST_LLM_ASSISTANT_PROVIDER")
        [[ -n "${TEST_LLM_PRIMARY_MODEL:-}" ]]          && _TEST_ENV_ARGS+=(-e "TEST_LLM_PRIMARY_MODEL=$TEST_LLM_PRIMARY_MODEL")
        [[ -n "${TEST_LLM_ASSISTANT_MODEL:-}" ]]        && _TEST_ENV_ARGS+=(-e "TEST_LLM_ASSISTANT_MODEL=$TEST_LLM_ASSISTANT_MODEL")
        [[ -n "${TEST_LLM_ENDPOINT_URL:-}" ]]           && _TEST_ENV_ARGS+=(-e "TEST_LLM_ENDPOINT_URL=$TEST_LLM_ENDPOINT_URL")
        [[ -n "${TEST_LLM_API_KEY:-}" ]]                && _TEST_ENV_ARGS+=(-e "TEST_LLM_API_KEY=$TEST_LLM_API_KEY")
        [[ -n "${TEST_LLM_ASSISTANT_ENDPOINT_URL:-}" ]] && _TEST_ENV_ARGS+=(-e "TEST_LLM_ASSISTANT_ENDPOINT_URL=$TEST_LLM_ASSISTANT_ENDPOINT_URL")
        [[ -n "${TEST_LLM_ASSISTANT_API_KEY:-}" ]]      && _TEST_ENV_ARGS+=(-e "TEST_LLM_ASSISTANT_API_KEY=$TEST_LLM_ASSISTANT_API_KEY")
        [[ -n "${TEST_WEB_SEARCH_PROJECT_ID:-}" ]]      && _TEST_ENV_ARGS+=(-e "TEST_WEB_SEARCH_PROJECT_ID=$TEST_WEB_SEARCH_PROJECT_ID")
        [[ -n "${TEST_WEB_SEARCH_ENGINE_ID:-}" ]]       && _TEST_ENV_ARGS+=(-e "TEST_WEB_SEARCH_ENGINE_ID=$TEST_WEB_SEARCH_ENGINE_ID")
        [[ -n "${TEST_WEB_SEARCH_API_KEY:-}" ]]         && _TEST_ENV_ARGS+=(-e "TEST_WEB_SEARCH_API_KEY=$TEST_WEB_SEARCH_API_KEY")
        [[ -n "${TEST_WEB_SEARCH_LOCATION:-}" ]]        && _TEST_ENV_ARGS+=(-e "TEST_WEB_SEARCH_LOCATION=$TEST_WEB_SEARCH_LOCATION")

        _ensure_container "$_TEST_RUNNER" "test $_TEST_COMPONENT"
        if [ -t 0 ] && [ -t 1 ]; then
            exec docker exec -it "${_TEST_ENV_ARGS[@]}" "$_TEST_RUNNER" /app/scripts/testing/run_tests.sh "${_TEST_PASSTHROUGH[@]}"
        else
            exec docker exec -i "${_TEST_ENV_ARGS[@]}" "$_TEST_RUNNER" /app/scripts/testing/run_tests.sh "${_TEST_PASSTHROUGH[@]}"
        fi ;;

    # ------------------------------------------------------------------
    # security — runs inside g8ep
    # ------------------------------------------------------------------
    security)
        case "$SUB" in
            validate)
                _banner "security validate"
                _exec_in_pod /app/scripts/security/validate-platform-security.sh "${@:3}" ;;
            certs)
                CERT_SUB="${3:-status}"
                case "$CERT_SUB" in
                    generate|rotate|status|trust)
                        _banner "security certs $CERT_SUB"
                        exec bash "$SCRIPT_DIR/scripts/security/manage-ssl.sh" "$CERT_SUB" "${@:4}" ;;
                    *)
                        echo "[g8e] unknown certs subcommand: '$CERT_SUB'" >&2
                        echo "  Valid: generate, rotate, status, trust" >&2
                        exit 1 ;;
                esac ;;
            mtls-test)
                _banner "security mtls-test"
                _exec_in_pod /app/scripts/security/mtls-test.sh "${@:3}" ;;
            scan-licenses)
                _banner "security scan-licenses"
                _exec_in_pod /app/scripts/security/scan-licenses.sh "${@:3}" ;;
            passkeys)
                _banner "security passkeys ${@:3}"
                _exec_in_pod /app/scripts/security/manage-passkeys.py "${@:3}" ;;
            rotate-internal-token)
                _banner "security rotate-internal-token"
                _ensure_g8ep "security rotate-internal-token"
                echo "  Rotating internal auth token..."
                _new_token="$(docker exec -i "$CONTAINER" python3 /app/scripts/data/manage-g8es.py settings rotate-token 2>&1)"
                if [[ -z "$_new_token" || "$_new_token" == *"Error"* ]]; then
                    echo "[g8e] Failed to rotate token: $_new_token" >&2
                    exit 1
                fi
                echo "  Token written to g8es."
                echo "  Restarting g8ed and g8ee to pick up new token..."
                docker compose -f "$SCRIPT_DIR/docker-compose.yml" restart g8ed g8ee
                echo ""
                echo "  Done. All components now use the new internal auth token." ;;
            "")
                echo "[g8e] missing subcommand for 'security'" >&2
                echo "  Valid: validate, certs, mtls-test, scan-licenses, passkeys, rotate-internal-token" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown security subcommand: '$SUB'" >&2
                echo "  Valid: validate, certs, mtls-test, scan-licenses, passkeys, rotate-internal-token" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # data — runs inside g8ep
    # ------------------------------------------------------------------
    data)
        case "$SUB" in
            users|operators|store|settings|audit|device-links)
                _banner "data $SUB ${@:3}"
                _exec_in_pod python3 /app/scripts/data/manage-g8es.py "$SUB" "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'data'" >&2
                echo "  Valid: users, operators, store, settings, audit, device-links" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown data subcommand: '$SUB'" >&2
                echo "  Valid: users, operators, store, settings, audit, device-links" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # demo — manages the broken-fleet demo; must run on host
    # ------------------------------------------------------------------
    demo)
        DEMO_DIR="$SCRIPT_DIR/demo"
        if [[ ! -d "$DEMO_DIR" ]]; then
            echo "[g8e] demo directory not found: $DEMO_DIR" >&2
            exit 1
        fi
        case "$SUB" in
            up|down|status|clean|health|nginx-check|operators|logs|deploy|discover-hosts|stream|vanish|dashboard)
                _banner "demo $SUB"
                exec make -C "$DEMO_DIR" "$SUB" "${@:3}" ;;
            shell)
                _banner "demo shell"
                exec make -C "$DEMO_DIR" shell "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'demo'" >&2
                echo "  Valid: up, down, status, clean, health, nginx-check, operators, logs, shell, deploy, discover-hosts, stream, vanish, dashboard" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown demo subcommand: '$SUB'" >&2
                echo "  Valid: up, down, status, clean, health, nginx-check, operators, logs, shell, deploy, discover-hosts, stream, vanish, dashboard" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # ssh — manages SSH credential mount; must run on host
    # ------------------------------------------------------------------
    ssh)
        case "$SUB" in
            setup)
                _banner "ssh setup"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-ssh.sh" "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'ssh'" >&2
                echo "  Valid: setup" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown ssh subcommand: '$SUB'" >&2
                echo "  Valid: setup" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # aws — manages AWS credential mount; must run on host
    # ------------------------------------------------------------------
    aws)
        case "$SUB" in
            setup)
                _banner "aws setup"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-aws.sh" "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'aws'" >&2
                echo "  Valid: setup" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown aws subcommand: '$SUB'" >&2
                echo "  Valid: setup" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # search — manages web search config; must run on host
    # ------------------------------------------------------------------
    search)
        case "$SUB" in
            setup)
                _banner "search setup"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-search.sh" "${@:3}" ;;
            disable)
                _banner "search disable"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-search.sh" --disable "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'search'" >&2
                echo "  Valid: setup, disable" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown search subcommand: '$SUB'" >&2
                echo "  Valid: setup, disable" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # mcp — MCP client integration; runs inside g8ep
    # ------------------------------------------------------------------
    mcp)
        case "$SUB" in
            config|test|status)
                _banner "mcp $SUB"
                _exec_in_pod python3 /app/scripts/data/manage-g8es.py mcp "$SUB" "${@:3}" ;;
            "")
                echo "[g8e] missing subcommand for 'mcp'" >&2
                echo "  Valid: config, test, status" >&2
                echo "" >&2
                echo "  Examples:" >&2
                echo "    ./g8e mcp config --client claude-code --email user@example.com" >&2
                echo "    ./g8e mcp test --email user@example.com" >&2
                echo "    ./g8e mcp status" >&2
                exit 1 ;;
            *)
                echo "[g8e] unknown mcp subcommand: '$SUB'" >&2
                echo "  Valid: config, test, status" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # llm — manages Docker container; must run on host
    # ------------------------------------------------------------------
    llm)
        case "$SUB" in
            setup|show|get|set|restart)
                # Forward to setup-llm.sh
                exec bash "$SCRIPT_DIR/scripts/tools/setup-llm.sh" "$SUB" "${@:3}" ;;
            "")
                exec bash "$SCRIPT_DIR/scripts/tools/setup-llm.sh" --help ;;
            *)
                echo "[g8e] unknown llm subcommand: '$SUB'" >&2
                echo "  Valid: setup, show, get, set, restart" >&2
                exit 1 ;;
        esac ;;

    *)
        echo "[g8e] unknown command: '$TOP'" >&2
        echo "  Run: ./g8e --help" >&2
        exit 1 ;;

esac
