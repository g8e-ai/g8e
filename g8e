    # ------------------------------------------------------------------
    # evals — manages eval fleet for real-operator evaluation scenarios
    # ------------------------------------------------------------------
    evals)
        EVALS_DIR="$SCRIPT_DIR/components/g8ee/evals"
        EVALS_COMPOSE="$EVALS_DIR/docker-compose.evals.yml"
        if [[ ! -f "$EVALS_COMPOSE" ]]; then
            echo "[g8e] evals compose file not found: $EVALS_COMPOSE" >&2
            exit 1
        fi
        
        # Collect LLM flags that might appear before or after the subcommand
        eval_llm_args=()
        filtered_eval_args=()
        i=1
        _eval_args=("${@:2}")
        while [[ $i -le ${#_eval_args[@]} ]]; do
            arg="${_eval_args[$((i-1))]}"
            case "$arg" in
                -p|--llm-provider)
                    eval_llm_args+=("-p" "${_eval_args[$i]}"); ((i+=2)) ;;
                -m|--primary-model)
                    eval_llm_args+=("-m" "${_eval_args[$i]}"); ((i+=2)) ;;
                -a|--assistant-model)
                    eval_llm_args+=("-a" "${_eval_args[$i]}"); ((i+=2)) ;;
                -l|--lite-model)
                    eval_llm_args+=("-l" "${_eval_args[$i]}"); ((i+=2)) ;;
                -e|--llm-endpoint-url)
                    eval_llm_args+=("-e" "${_eval_args[$i]}"); ((i+=2)) ;;
                -k|--llm-api-key)
                    eval_llm_args+=("-k" "${_eval_args[$i]}"); ((i+=2)) ;;
                *)
                    filtered_eval_args+=("$arg"); ((i++)) ;;
            esac
        done
        
        # Reset SUB and subsequent args based on filtered list
        SUB="${filtered_eval_args[0]:-}"
        REMAINING_ARGS=("${filtered_eval_args[@]:1}")

        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### evals/,/^## DETAILED HELP/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            run)
                _args=("${REMAINING_ARGS[@]}")
                if [[ ${#_args[@]} -eq 0 ]]; then
                    echo "Usage: ./g8e evals run --gold-set <path>" >&2
                    exit 1
                fi
                
                run_args=("${eval_llm_args[@]}")
                gold_set=""
                set -- "${_args[@]}"
                while [[ "$#" -gt 0 ]]; do
                    case "$1" in
                        -d|--device-token) run_args+=("--device-token" "$2"); shift 2 ;;
                        --gold-set)
                            gold_set="$2"
                            if [[ "$gold_set" != /* ]]; then
                                gold_set="$SCRIPT_DIR/$gold_set"
                            fi
                            gold_set="/app/components/g8ee${gold_set#$SCRIPT_DIR/components/g8ee}"
                            run_args+=("--gold-set" "$gold_set")
                            shift 2
                            ;;
                        --dry-run) run_args+=("--dry-run"); shift 1 ;;
                        *) run_args+=("$1"); shift 1 ;;
                    esac
                done
                
                _banner "evals run"
                _ensure_g8ep "evals run"
                docker exec -i -e "G8E_SHARED_DIR=/app/shared" -e "PYTHONPATH=/app/components/g8ee:/app/shared" "$CONTAINER" python -m app.evals.runner.cli "${run_args[@]}"
                ;;
    up)
                _banner "evals up"
                _nodes=3
                _device_token=""
                _args=("${@:3}")
                while [[ $# -gt 2 ]]; do
                    case "${3:-}" in
                        --nodes) _nodes="${4:-3}"; shift 2 ;;
                        -d|--device-token) _device_token="${4:-}"; shift 2 ;;
                        *) echo "[g8e] unknown option: '${3}'"; exit 1 ;;
                    esac
                done
                if [[ -z "$_device_token" ]]; then
                    echo "[g8e] evals up requires --device-token" >&2
                    echo "  Generate a device link token from the dashboard" >&2
                    exit 1
                fi
                echo "  Bringing up $_nodes eval nodes..."
                DEVICE_TOKEN="$_device_token" COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" up -d --build --scale eval-node="$_nodes"
                echo ""
                echo "  Eval fleet is up. Check status with: ./g8e evals status"
                exit 0 ;;
            down)
                _banner "evals down"
                COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" down
                echo ""
                echo "  Eval fleet is down."
                exit 0 ;;
            status)
                _banner "evals status"
                COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" ps
                exit 0 ;;
            logs)
                _banner "evals logs ${3:-}"
                if [[ -z "${3:-}" ]]; then
                    echo "[g8e] evals logs requires a node name" >&2
                    echo "  Usage: ./g8e evals logs <node-name>" >&2
                    exit 1
                fi
                docker logs -f "${3}"
                exit 0 ;;
            list)
                _banner "evals list"
                _ensure_g8ep "evals list"
                docker exec -i -e "G8E_SHARED_DIR=/app/shared" -e "PYTHONPATH=/app/components/g8ee:/app/shared" "$CONTAINER" python -m app.evals.runner.cli list
                ;;
            *)
                echo "[g8e] unknown evals subcommand: '$SUB'" >&2
                echo "  Valid: run, list, up, down, status, logs" >&2
                exit 1 ;;
        esac ;;

    *)
        echo "[g8e] unknown command: '$TOP'" >&2
        echo "  Run: ./g8e --help" >&2
        exit 1 ;;

esac
