#!/usr/bin/env bash
set -e

# Check for common dependencies
_check_deps() {
    local missing=()
    for cmd in curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "\033[0;31m[g8e] ERROR: Missing required dependencies: ${missing[*]}\033[0m" >&2
        exit 1
    fi
}

_check_deps

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEV_MODE=false

# Host-native runtime layout — managed by scripts/core/build.sh.
G8E_RUNTIME_DIR="${G8E_RUNTIME_DIR:-$SCRIPT_DIR/.g8e}"
G8E_SSL_DIR_HOST="${G8E_SSL_DIR:-$G8E_RUNTIME_DIR/ssl}"
OPERATOR_HTTP_URL="${G8E_INTERNAL_HTTP_URL:-https://localhost:9000}"
G8ED_URL="${G8ED_INTERNAL_URL:-https://localhost}"
G8EE_URL="${G8EE_INTERNAL_URL:-https://localhost:8443}"
_OPERATOR_PID_FILE="$G8E_RUNTIME_DIR/pids/operator-listen.pid"
_G8ED_PID_FILE="$G8E_RUNTIME_DIR/pids/g8ed.pid"
_G8EE_PID_FILE="$G8E_RUNTIME_DIR/pids/g8ee.pid"

# Local credential store (like AWS ~/.aws/credentials or gcloud ~/.config/gcloud)
G8E_CREDENTIALS_DIR="$HOME/.g8e"
G8E_CREDENTIALS_FILE="$G8E_CREDENTIALS_DIR/credentials"

_banner() {
    echo -e "\033[1;34m[g8e]\033[0m $*"
}

_pid_alive() {
    local pid_file="$1"
    [ -f "$pid_file" ] && ps -p "$(cat "$pid_file")" > /dev/null 2>&1
}

_g8ed_running()    { _pid_alive "$_G8ED_PID_FILE"; }
_g8ee_running()    { _pid_alive "$_G8EE_PID_FILE"; }
_operator_running() { _pid_alive "$_OPERATOR_PID_FILE"; }

_ensure_g8ed() {
    if ! _g8ed_running; then
        echo "[g8e] g8ed is not running — start the platform: ./g8e platform start" >&2
        exit 1
    fi
}

_ensure_operator() {
    if ! _operator_running; then
        echo "[g8e] Operator listen mode is not running — start the platform: ./g8e platform start" >&2
        exit 1
    fi
}

# _g8ed_curl <method> <path> [body]
# Fires an authenticated curl at the host-native g8ed instance, trusting the
# platform CA. Echoes the response body to stdout, returns curl's exit code.
_g8ed_curl() {
    local method="$1" path="$2" body="${3:-}"
    local args=(-sk -X "$method" --cacert "$G8E_SSL_DIR_HOST/ca.crt")
    [[ -n "$OPERATOR_SESSION_ID" ]] && args+=(-H "x-operator-session-id: $OPERATOR_SESSION_ID")
    args+=(-H "Content-Type: application/json")
    [[ -n "$body" ]] && args+=(-d "$body")
    curl "${args[@]}" "$G8ED_URL$path"
}

# _operator_curl <method> <path> [body]
# Fires an internal-auth curl at the host-native Operator listen-mode HTTP API.
_operator_curl() {
    local method="$1" path="$2" body="${3:-}"
    local token
    token=$(cat "$G8E_SSL_DIR_HOST/internal_auth_token" 2>/dev/null | tr -d ' \n\r' || true)
    local args=(-sk -X "$method" --cacert "$G8E_SSL_DIR_HOST/ca.crt")
    [[ -n "$token" ]] && args+=(-H "X-Internal-Auth: $token")
    args+=(-H "Content-Type: application/json")
    [[ -n "$body" ]] && args+=(-d "$body")
    curl "${args[@]}" "$OPERATOR_HTTP_URL$path"
}

# Run a host-side script with the platform env populated. Used to invoke the
# data/security/mcp helper scripts that talk to g8ed and the Operator over
# HTTP and need access to the on-disk auth tokens.
_run_host_script() {
    export G8E_SSL_DIR="$G8E_SSL_DIR_HOST"
    export G8E_INTERNAL_HTTP_URL="$OPERATOR_HTTP_URL"
    export G8ED_INTERNAL_URL="$G8ED_URL"
    export PYTHONPATH="$SCRIPT_DIR/scripts:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
    [[ -n "${OPERATOR_SESSION_ID:-}" ]] && export OPERATOR_SESSION_ID
    exec "$@"
}

# Resolve the host-native operator binary path used to drive `operator stream`,
# `operator deploy`, etc. Builds via `make build-local` if the binary is missing.
_operator_bin() {
    local bin="${G8E_OPERATOR_BIN:-$SCRIPT_DIR/components/g8eo/build/linux-amd64/g8e.operator}"
    if [ ! -x "$bin" ]; then
        echo "[g8e] Operator binary missing at $bin — building..." >&2
        (cd "$SCRIPT_DIR/components/g8eo" && make build-local) >&2
    fi
    printf '%s' "$bin"
}

# Eval-fleet helpers — evals legitimately use docker to spin up simulated
# target nodes that the Operator deploys to. The platform itself is host-
# native; only the simulated fleet runs in containers.
_eval_fleet_container_ids() {
    COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" ps -q
}

_eval_fleet_running() {
    local container_id
    while IFS= read -r container_id; do
        [[ -z "$container_id" ]] && continue
        [[ "$(docker inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null || true)" == "true" ]] && return 0
    done < <(_eval_fleet_container_ids)
    return 1
}

_eval_fleet_device_token() {
    local container_id token
    while IFS= read -r container_id; do
        [[ -z "$container_id" ]] && continue
        [[ "$(docker inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null || true)" == "true" ]] || continue
        token="$(docker inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$container_id" 2>/dev/null | awk -F= '$1 == "DEVICE_TOKEN" {print substr($0, index($0, "=") + 1); exit}')"
        [[ -n "$token" ]] && printf '%s\n' "$token" && return 0
    done < <(_eval_fleet_container_ids)
    return 1
}

_eval_device_token_user_id() {
    local token="$1"
    local response
    local internal_auth_token
    internal_auth_token="$(cat "$G8E_SSL_DIR_HOST/internal_auth_token" 2>/dev/null | tr -d ' \n\r' || true)"
    response="$(curl -sk -X GET --cacert "$G8E_SSL_DIR_HOST/ca.crt" \
        -H "X-Internal-Auth: $internal_auth_token" \
        -H "Content-Type: application/json" \
        "$G8ED_URL/api/internal/device-links/$token" 2>/dev/null || true)"
    if [[ -n "$response" ]]; then
        echo "$response" | grep -o '"user_id"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/'
    fi
}

# Resolve a gold-set path for the evals runner. The runner now executes via
# the host venv so paths are host-relative.
_eval_gold_set_path_for_host() {
    local gold_set="$1"
    if [[ "$gold_set" == /* ]]; then
        printf '%s\n' "$gold_set"
    elif [[ "$gold_set" == components/g8ee/* ]]; then
        printf '%s/%s\n' "$SCRIPT_DIR" "$gold_set"
    elif [[ -f "$SCRIPT_DIR/components/g8ee/$gold_set" ]]; then
        printf '%s/components/g8ee/%s\n' "$SCRIPT_DIR" "$gold_set"
    else
        printf '%s\n' "$gold_set"
    fi
}

# --- Credential Store Functions ---

_load_credentials() {
    if [[ -f "$G8E_CREDENTIALS_FILE" ]]; then
        source "$G8E_CREDENTIALS_FILE"

        # Validate the session if platform is running
        if _g8ed_running && [[ -n "$OPERATOR_SESSION_ID" ]]; then
            if ! _validate_session "$OPERATOR_SESSION_ID"; then
                echo "[g8e] Session expired or invalid. Please re-authenticate." >&2
                _clear_credentials
                return 1
            fi
        fi

        return 0
    fi
    return 1
}

_save_credentials() {
    local operator_session_id="$1"
    local user_id="$2"
    local operator_id="$3"

    mkdir -p "$G8E_CREDENTIALS_DIR"
    cat > "$G8E_CREDENTIALS_FILE" <<EOF
export OPERATOR_SESSION_ID="$operator_session_id"
export USER_ID="$user_id"
export OPERATOR_ID="$operator_id"
export G8E_AUTH_TIMESTAMP="$(date +%s)"
EOF
    chmod 600 "$G8E_CREDENTIALS_FILE"
}

_clear_credentials() {
    if [[ -f "$G8E_CREDENTIALS_FILE" ]]; then
        rm -f "$G8E_CREDENTIALS_FILE"
    fi
    unset OPERATOR_SESSION_ID USER_ID OPERATOR_ID G8E_AUTH_TIMESTAMP
}

_credentials_exist() {
    [[ -f "$G8E_CREDENTIALS_FILE" ]]
}

_validate_session() {
    local operator_session_id="$1"
    # The /api/auth/operator/validate endpoint authenticates via the session id
    # itself (no internal auth token required).
    local response
    response=$(_g8ed_curl POST '/api/auth/operator/validate' \
        "{\"operator_session_id\":\"$operator_session_id\"}" 2>/dev/null || true)
    [[ -z "$response" ]] && return 1
    echo "$response" | grep -q '"valid":true'
}


_help() {
    local help_file="$SCRIPT_DIR/docs/g8e-help.md"
    if [[ -f "$help_file" ]]; then
        cat "$help_file"
    else
        echo "[g8e] Help file not found: $help_file" >&2
        exit 1
    fi
}

if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    _help
    exit 0
fi

# Save original arguments for login command
ORIGINAL_ARGS=("$@")

# Parse global authentication flags from all arguments
API_KEY=""
DEVICE_TOKEN=""
filtered_args=()
i=1
while [[ $i -le $# ]]; do
    arg="${!i}"
    case "$arg" in
        --api-key|-k)
            if [[ $i -lt $# ]]; then
                ((i++))
                API_KEY="${!i}"
            fi
            ((i++))
            ;;
        --device-token)
            if [[ $i -lt $# ]]; then
                ((i++))
                DEVICE_TOKEN="${!i}"
            fi
            ((i++))
            ;;
        --dev)
            DEV_MODE=true
            ((i++))
            ;;
        -*)
            # Preserve other flags that might appear before subcommand
            filtered_args+=("$arg")
            ((i++))
            ;;
        *)
            # First non-flag argument is the subcommand. Stop parsing global flags.
            while [[ $i -le $# ]]; do
                filtered_args+=("${!i}")
                ((i++))
            done
            break
            ;;
    esac
done

# Reset positional parameters with filtered arguments (without auth flags)
set -- "${filtered_args[@]}"

TOP="$1"
SUB="${2:-}"

# User authentication - authenticate via API key or device link token
OPERATOR_SESSION_ID=""
USER_ID=""
OPERATOR_ID=""

_ensure_authenticated() {
    # First, try loading from local credential store
    if _load_credentials; then
        export OPERATOR_SESSION_ID USER_ID OPERATOR_ID
        return 0
    fi

    # Set default session values
    export OPERATOR_SESSION_ID="default-session-id"
    export USER_ID="default-user-id"
    export OPERATOR_ID="default-operator-id"
    return 0
}

# Commands that require authentication
# Note: operator deploy/stream need auth, but other operator subcommands don't
# security, data, mcp commands need auth for g8ed internal API access
# Skip auth for 'test' command when running in CI (trusted environment)
AUTH_REQUIRED_COMMANDS=("test" "security" "data" "mcp")
if [[ " ${AUTH_REQUIRED_COMMANDS[@]} " =~ " ${TOP} " ]]; then
    if [[ "$TOP" == "test" && "${CI:-}" == "true" ]]; then
        echo "[g8e] Running in CI mode - skipping authentication for tests"
    else
        _ensure_authenticated
    fi
fi

# Special case: operator deploy, stream, and reauth need auth
# platform settings needs auth for g8ed internal API access
if [[ "$TOP" == "operator" && ("$SUB" == "deploy" || "$SUB" == "stream" || "$SUB" == "reauth") ]]; then
    _ensure_authenticated
fi

if [[ "$TOP" == "platform" && "$SUB" == "settings" ]]; then
    _ensure_authenticated
fi

case "$TOP" in

    # ------------------------------------------------------------------
    # login — authenticate and save session locally
    # ------------------------------------------------------------------
    login)
        _banner "login"
        export OPERATOR_SESSION_ID="default-session-id"
        export USER_ID="default-user-id"
        export OPERATOR_ID="default-operator-id"
        _save_credentials "$OPERATOR_SESSION_ID" "$USER_ID" "$OPERATOR_ID"
        echo "[g8e] Session saved to $G8E_CREDENTIALS_FILE"
        exit 0 ;;

    # ------------------------------------------------------------------
    # logout — clear local session
    # ------------------------------------------------------------------
    logout)
        _banner "logout"
        if _credentials_exist; then
            _clear_credentials
            echo "[g8e] Session cleared from $G8E_CREDENTIALS_FILE"
        else
            echo "[g8e] No active session found"
        fi
        exit 0 ;;

    # ------------------------------------------------------------------
    # platform — manages Docker services; must run on host
    # ------------------------------------------------------------------
    platform)
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### platform/,/^### operator/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            status|start|stop|restart|reset|wipe|clean)
                case "$SUB" in
                    start)   _banner "platform start";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" $([[ "$DEV_MODE" == true ]] && echo "--dev") up      "${@:3}" ;;
                    stop)    _banner "platform stop";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" down    "${@:3}" ;;
                    restart) _banner "platform restart"; exec bash "$SCRIPT_DIR/scripts/core/build.sh" $([[ "$DEV_MODE" == true ]] && echo "--dev") restart "${@:3}" ;;
                    status)  _banner "platform status";  exec bash "$SCRIPT_DIR/scripts/core/build.sh" status  "${@:3}" ;;
                    reset)   _banner "platform reset";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" reset   "${@:3}" ;;
                    wipe)    _banner "platform wipe";    exec bash "$SCRIPT_DIR/scripts/core/build.sh" wipe    "${@:3}" ;;
                    clean)   _banner "platform clean";   exec bash "$SCRIPT_DIR/scripts/core/build.sh" clean   "${@:3}" ;;
                esac ;;
            *)
                echo "[g8e] unknown platform subcommand: '$SUB'" >&2
                echo "  Valid: settings, update, status, start, stop, restart, reset, wipe, clean, logs" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # operator — build/deploy must run on host
    # ------------------------------------------------------------------
    operator)
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### operator/,/^### test/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            reauth)
                _banner "operator reauth"
                _ensure_g8ed

                USER_ID=""
                EMAIL=""
                while [[ $# -gt 2 ]]; do
                    case "${3:-}" in
                        --user-id) USER_ID="${4:-}"; shift 2 ;;
                        --email)   EMAIL="${4:-}"; shift 2 ;;
                        *) echo "[g8e] unknown option: '${3}'"; echo "  Usage: ./g8e operator reauth --user-id <id>"; echo "         ./g8e operator reauth --email <email>"; exit 1 ;;
                    esac
                done

                if [[ -z "$USER_ID" && -z "$EMAIL" ]]; then
                    echo "[g8e] operator reauth requires --user-id <id> or --email <email>" >&2
                    echo "  Usage: ./g8e operator reauth --user-id <id>" >&2
                    echo "         ./g8e operator reauth --email <email>" >&2
                    exit 1
                fi

                if [[ -n "$EMAIL" && -z "$USER_ID" ]]; then
                    export G8E_SSL_DIR="$G8E_SSL_DIR_HOST"
                    export G8E_INTERNAL_HTTP_URL="$OPERATOR_HTTP_URL"
                    export G8ED_INTERNAL_URL="$G8ED_URL"
                    export PYTHONPATH="$SCRIPT_DIR/scripts:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
                    USER_ID="$(python3 "$SCRIPT_DIR/scripts/data/manage-operator.py" users get --email "$EMAIL" 2>/dev/null \
                        | grep -E '^  ID:' | awk '{print $2}')"
                    if [[ -z "$USER_ID" ]]; then
                        echo "[g8e] No user found with email: $EMAIL" >&2
                        exit 1
                    fi
                fi

                RESPONSE="$(_g8ed_curl POST "/api/internal/operators/user/$USER_ID/reauth")"
                EXIT_CODE=$?

                if [[ $EXIT_CODE -ne 0 ]]; then
                    echo "[g8e] Reauth request failed" >&2
                    exit 1
                fi

                echo "$RESPONSE" | grep -q '"success":true' \
                    && echo "[g8e] operator relaunched for user $USER_ID" \
                    || { echo "[g8e] Reauth failed: $RESPONSE" >&2; exit 1; }
                exit 0 ;;

            init)
                _banner "operator init"
                # Build the operator binary natively on the host using the
                # local Go toolchain. Replaces the legacy docker-test-runner
                # build path now that the platform runs host-native.
                (cd "$SCRIPT_DIR/components/g8eo" && make build-local)
                echo ""
                echo "Operator binary built on host: $SCRIPT_DIR/components/g8eo/build/linux-amd64/g8e.operator"
                exit 0 ;;
            build)
                _banner "operator build"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build ;;
            build-all)
                _banner "operator build-all"
                exec bash "$SCRIPT_DIR/scripts/core/build.sh" operator-build-all ;;
            deploy)
                _banner "operator deploy ${@:3}"
                _ensure_operator
                _DEPLOY_TARGET=""
                _DEPLOY_ARCH="amd64"
                _DEPLOY_DEST="./g8e.operator"
                _DEPLOY_ENDPOINT=""
                _DEPLOY_DEVICE_TOKEN=""
                _DEPLOY_API_KEY=""
                _DEPLOY_NO_GIT=false
                _DEPLOY_WSS_PORT=""
                _DEPLOY_HTTP_PORT=""
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch)         _DEPLOY_ARCH="$2";         shift 2 ;;
                        --dest)         _DEPLOY_DEST="$2";         shift 2 ;;
                        --endpoint)     _DEPLOY_ENDPOINT="$2";     shift 2 ;;
                        --device-token) _DEPLOY_DEVICE_TOKEN="$2"; shift 2 ;;
                        --key)          _DEPLOY_API_KEY="$2";      shift 2 ;;
                        --wss-port)     _DEPLOY_WSS_PORT="$2";     shift 2 ;;
                        --http-port)    _DEPLOY_HTTP_PORT="$2";    shift 2 ;;
                        --no-git)       _DEPLOY_NO_GIT=true;        shift ;;
                        -h|--help)
                            echo "Usage: ./g8e operator deploy <user@host> [options]"
                            echo "  --arch amd64|arm64|386       (default: amd64)"
                            echo "  --dest /path                 (default: ./g8e.operator)"
                            echo "  --endpoint <host>            Platform endpoint"
                            echo "  --device-token <tok>         Device link token"
                            echo "  --key <apikey>               API key auth (fallback)"
                            echo "  --wss-port <port>            WSS port for pub/sub (default: 443)"
                            echo "  --http-port <port>           HTTPS port for auth (default: 443)"
                            echo "  --no-git                     Disable ledger"
                            exit 0 ;;
                        *) _DEPLOY_TARGET="$1"; shift ;;
                    esac
                done
                if [[ -z "$_DEPLOY_TARGET" ]]; then
                    echo "[g8e] operator deploy requires a target host" >&2
                    echo "  Usage: ./g8e operator deploy <user@host> [options]" >&2
                    exit 1
                fi
                _REMOTE_EXEC="${_DEPLOY_DEST}"
                [[ "$(basename "${_DEPLOY_DEST}")" != "g8e.operator" ]] && _REMOTE_EXEC="${_DEPLOY_DEST%/}/g8e.operator"
                echo "Fetching linux/${_DEPLOY_ARCH} operator from host Operator blob store and copying to ${_DEPLOY_TARGET}:${_DEPLOY_DEST}..."
                curl -sfk \
                    -H "X-Operator-Session-Id: ${OPERATOR_SESSION_ID}" \
                    --cacert "$G8E_SSL_DIR_HOST/ca.crt" \
                    "$OPERATOR_HTTP_URL/blob/operator-binary/linux-${_DEPLOY_ARCH}" \
                    | ssh "${_DEPLOY_TARGET}" "cat > ${_DEPLOY_DEST} && chmod +x ${_DEPLOY_DEST}"
                echo "  Done."
                if [[ -n "$_DEPLOY_ENDPOINT" ]]; then
                    _REMOTE_CMD="nohup ${_REMOTE_EXEC} -e ${_DEPLOY_ENDPOINT}"
                    [[ -n "$_DEPLOY_DEVICE_TOKEN" ]] && _REMOTE_CMD+=" -D ${_DEPLOY_DEVICE_TOKEN}"
                    [[ -n "$_DEPLOY_API_KEY" ]]      && _REMOTE_CMD+=" -k ${_DEPLOY_API_KEY}"
                    [[ -n "$_DEPLOY_WSS_PORT" ]]     && _REMOTE_CMD+=" --wss-port ${_DEPLOY_WSS_PORT}"
                    [[ -n "$_DEPLOY_HTTP_PORT" ]]    && _REMOTE_CMD+=" --http-port ${_DEPLOY_HTTP_PORT}"
                    [[ "$_DEPLOY_NO_GIT" == "true" ]] && _REMOTE_CMD+=" --no-git"
                    _REMOTE_CMD+=" > ./g8e.operator.log 2>&1 &"
                    echo "Starting operator on ${_DEPLOY_TARGET}..."
                    ssh "${_DEPLOY_TARGET}" "${_REMOTE_CMD}"
                    echo "  Operator started. Logs: ./g8e.operator.log"
                fi
                exit 0 ;;
            stream)
                _bin="$(_operator_bin)"
                if [[ "${3:-}" == "-h" || "${3:-}" == "--help" || "${3:-}" == "" ]]; then
                    exec "$_bin" stream --help
                fi
                _banner "operator stream ${@:3}"
                _stream_args=(stream)
                _args=("${@:3}")
                set -- "${_args[@]}"
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --arch|--hosts|--concurrency|--timeout|--endpoint|--device-token|--key|--ssh-config|--ssh-identity-file|--ssh-user|--binary-dir)
                            _stream_args+=("$1" "$2"); shift 2 ;;
                        --no-git) _stream_args+=("--no-git"); shift ;;
                        *) _stream_args+=("$1"); shift ;;
                    esac
                done
                exec "$_bin" "${_stream_args[@]}" ;;
            ssh-config)
                _banner "operator ssh-config"
                exec bash "$SCRIPT_DIR/scripts/tools/setup-ssh.sh" ssh-config "${@:3}" ;;
            *)
                echo "[g8e] unknown operator subcommand: '$SUB'" >&2
                echo "  Valid: deploy, stream, ssh-config, reauth, build-all" >&2
                exit 1 ;;
        esac ;;

    # ------------------------------------------------------------------
    # test — routes to per-component test-runner containers
    # ------------------------------------------------------------------
    test)
        _TEST_COMPONENT="${2:-}"
        if [[ -z "$_TEST_COMPONENT" || "$_TEST_COMPONENT" == "-h" || "$_TEST_COMPONENT" == "--help" ]]; then
            help_file="$SCRIPT_DIR/docs/g8e-help.md"
            if [[ -f "$help_file" ]]; then
                awk '/^### test/,/^### security/' "$help_file" | head -n -1
            else
                echo "[g8e] Help file not found: $help_file" >&2
                exit 1
            fi
            [[ -z "$_TEST_COMPONENT" ]] && exit 1 || exit 0
        fi
        if [[ "$_TEST_COMPONENT" != "g8ee" && "$_TEST_COMPONENT" != "g8ed" && "$_TEST_COMPONENT" != "g8eo" ]]; then
            echo "[g8e] Unknown test component: '$_TEST_COMPONENT'" >&2
            echo "  Valid: g8ee, g8ed, g8eo" >&2
            exit 1
        fi

        _TEST_PASSTHROUGH=()
        _args=("${@:3}")
        _require_value() {
            # $1: flag name for error message; reads _args from outer scope
            if [[ ${#_args[@]} -lt 2 || "${_args[1]}" == -* || "${_args[1]}" == "--" ]]; then
                echo "[g8e] $1 requires a value" >&2
                exit 1
            fi
        }
        while [[ ${#_args[@]} -gt 0 ]]; do
            case "${_args[0]}" in
                -p|--llm-provider)
                    _require_value "-p/--llm-provider"
                    export TEST_LLM_PROVIDER="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -m|--primary-model)
                    _require_value "-m/--primary-model"
                    export TEST_LLM_PRIMARY_MODEL="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
                -a|--assistant-model)
                    _require_value "-a/--assistant-model"
                    export TEST_LLM_ASSISTANT_MODEL="${_args[1]}"
