    # ------------------------------------------------------------------
    # evals — manages eval fleet for real-operator evaluation scenarios
    # ------------------------------------------------------------------
    evals)
        EVALS_DIR="$SCRIPT_DIR/components/g8ee/evals"
        EVALS_COMPOSE="$EVALS_DIR/docker-compose.evals.yml"
        if [[ ! -f "$EVALS_COMPOSE" ]]; then
            echo "[g8e] evals compose file not found: $EVALS_COMPOSE" >&2
            exit 1
        fi
        
        # Collect LLM flags that might appear before or after the subcommand
        eval_llm_args=()
        filtered_eval_args=()
        i=1
        _eval_args=("${@:2}")
        while [[ $i -le ${#_eval_args[@]} ]]; do
            arg="${_eval_args[$((i-1))]}"
            case "$arg" in
                -p|--llm-provider)
                    eval_llm_args+=("-p" "${_eval_args[$i]}"); i=$((i+2)) ;;
                -m|--primary-model)
                    eval_llm_args+=("-m" "${_eval_args[$i]}"); i=$((i+2)) ;;
                -a|--assistant-model)
                    eval_llm_args+=("-a" "${_eval_args[$i]}"); i=$((i+2)) ;;
                -l|--lite-model)
                    eval_llm_args+=("-l" "${_eval_args[$i]}"); i=$((i+2)) ;;
                -e|--llm-endpoint-url)
                    eval_llm_args+=("-e" "${_eval_args[$i]}"); i=$((i+2)) ;;
                -k|--llm-api-key)
                    eval_llm_args+=("-k" "${_eval_args[$i]}"); i=$((i+2)) ;;
                *)
                    filtered_eval_args+=("$arg"); i=$((i+1)) ;;
            esac
        done
        
        # Reset SUB and subsequent args based on filtered list
        SUB="${filtered_eval_args[0]:-}"
        REMAINING_ARGS=("${filtered_eval_args[@]:1}")

        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### evals/,/^## DETAILED HELP/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            run)
                _args=("${REMAINING_ARGS[@]}")
                if [[ ${#_args[@]} -eq 0 ]]; then
                    echo "Usage: ./g8e evals run --gold-set <path>" >&2
                    exit 1
                fi
                
                run_args=("${eval_llm_args[@]}")
                gold_set=""
                device_token=""
                set -- "${_args[@]}"
                while [[ "$#" -gt 0 ]]; do
                    case "$1" in
                        -d|--device-token)
                            device_token="$2"
                            run_args+=("--device-token" "$device_token")
                            shift 2
                            ;;
                        --gold-set)
                            gold_set="$(_eval_gold_set_path_for_host "$2")"
                            run_args+=("--gold-set" "$gold_set")
                            shift 2
                            ;;
                        --dry-run) run_args+=("--dry-run"); shift 1 ;;
                        *) run_args+=("$1"); shift 1 ;;
                    esac
                done

                if ! _eval_fleet_running; then
                    echo "[g8e] eval fleet is not running" >&2
                    echo "  Start it first: ./g8e evals up --device-token <token>" >&2
                    exit 1
                fi

                if [[ -n "$device_token" ]]; then
                    # Ensure the fleet is running with this token
                    _nodes=$(docker ps --filter "label=io.g8e.evals=true" --format '{{.Names}}' | wc -l)
                    [[ $_nodes -eq 0 ]] && _nodes=3
                    echo "[g8e] Ensuring eval fleet is running with provided DEVICE_TOKEN..."
                    DEVICE_TOKEN="$device_token" COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" up -d --scale eval-node="$_nodes" >/dev/null 2>&1
                elif device_token="$(_eval_fleet_device_token)"; then
                    run_args+=("--device-token" "$device_token")
                else
                    echo "[g8e] Error: No DEVICE_TOKEN provided and none found in running fleet" >&2
                    echo "  Usage: ./g8e evals run --device-token <token> --gold-set <path>" >&2
                    echo "     or: ./g8e evals up --device-token <token> && ./g8e evals run --gold-set <path>" >&2
                    exit 1
                fi

                # Configure USER LLM settings from CLI arguments
                if [[ ${#eval_llm_args[@]} -gt 0 ]]; then
                    user_id="$(_eval_device_token_user_id "$device_token")"
                    if [[ -z "$user_id" ]]; then
                        echo "[g8e] Error: Could not resolve user_id from device token - device link may not exist or is corrupted" >&2
                        exit 1
                    fi
                    echo "[g8e] Configuring USER LLM settings for user: $user_id"
                    settings_args=()
                    i=0
                    while [[ $i -lt ${#eval_llm_args[@]} ]]; do
                        flag="${eval_llm_args[$i]}"
                        value="${eval_llm_args[$((i+1))]}"
                        case "$flag" in
                            -p) settings_args+=("llm_provider=$value") ;;
                            -m) settings_args+=("llm_model=$value") ;;
                            -a) settings_args+=("llm_assistant_model=$value") ;;
                            -l) settings_args+=("llm_lite_model=$value") ;;
                            -e) settings_args+=("llm_endpoint=$value") ;;
                            -k) 
                                provider=""
                                for j in "${!eval_llm_args[@]}"; do
                                    if [[ "${eval_llm_args[$j]}" == "-p" && $j -lt ${#eval_llm_args[@]} ]]; then
                                        provider="${eval_llm_args[$((j+1))]}"
                                        break
                                    fi
                                done
                                case "$provider" in
                                    gemini) settings_args+=("gemini_api_key=$value") ;;
                                    openai) settings_args+=("openai_api_key=$value") ;;
                                    anthropic) settings_args+=("anthropic_api_key=$value") ;;
                                    ollama) settings_args+=("ollama_api_key=$value") ;;
                                    *) settings_args+=("gemini_api_key=$value") ;;
                                esac
                                ;;
                        esac
                        i=$((i+2))
                    done

                    if [[ ${#settings_args[@]} -gt 0 ]]; then
                        _ensure_g8ed
                        (
                            export G8E_SSL_DIR="$G8E_SSL_DIR_HOST"
                            export G8E_INTERNAL_HTTP_URL="$OPERATOR_HTTP_URL"
                            export G8ED_INTERNAL_URL="$G8ED_URL"
                            export PYTHONPATH="$SCRIPT_DIR/scripts:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
                            python3 "$SCRIPT_DIR/scripts/data/manage-operator.py" settings set --user-id "$user_id" "${settings_args[@]}"
                        )
                    fi
                fi

                _banner "evals run"
                _venv="$SCRIPT_DIR/components/g8ee/.venv"
                if [ ! -x "$_venv/bin/python" ]; then
                    echo "[g8e] g8ee virtualenv missing at $_venv — run ./g8e platform start first" >&2
                    exit 1
                fi
                (
                    cd "$SCRIPT_DIR/components/g8ee"
                    export PYTHONPATH="$SCRIPT_DIR/components/g8ee:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
                    export G8E_SHARED_DIR="$SCRIPT_DIR/shared"
                    export G8E_SSL_DIR="$G8E_SSL_DIR_HOST"
                    export G8E_INTERNAL_HTTP_URL="$OPERATOR_HTTP_URL"
                    export G8ED_URL="$G8ED_URL"
                    export G8EE_URL="$G8EE_URL"
                    "$_venv/bin/python" -m app.evals.runner.cli run "${run_args[@]}"
                )
                ;;
            up)
                _banner "evals up"
                _nodes=3
                _device_token=""
                _auto_created=false
                _args=("${@:3}")
                while [[ $# -gt 2 ]]; do
                    case "${3:-}" in
                        --nodes) _nodes="${4:-3}"; shift 2 ;;
                        -d|--device-token) _device_token="${4:-}"; shift 2 ;;
                        *) echo "[g8e] unknown option: '${3}'"; exit 1 ;;
                    esac
                done
                
                # Auto-create user and device link if no token provided
                if [[ -z "$_device_token" ]]; then
                    _ensure_g8ed
                    echo "  No device token provided, checking for evals user..."
                    
                    # Check if evals user exists
                    export G8E_SSL_DIR="$G8E_SSL_DIR_HOST"
                    export G8E_INTERNAL_HTTP_URL="$OPERATOR_HTTP_URL"
                    export G8ED_INTERNAL_URL="$G8ED_URL"
                    export PYTHONPATH="$SCRIPT_DIR/scripts:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
                    
                    _user_id="$(python3 "$SCRIPT_DIR/scripts/data/manage-operator.py" users get --email evals@localhost 2>/dev/null | grep -E '^  ID:' | awk '{print $2}' || true)"
                    
                    if [[ -z "$_user_id" ]]; then
                        echo "  Creating evals user (evals@localhost)..."
                        _user_id="$(python3 "$SCRIPT_DIR/scripts/data/manage-operator.py" users create --email evals@localhost --name "Evals User" 2>/dev/null | grep -E '^  ID:' | awk '{print $2}' || true)"
                        if [[ -z "$_user_id" ]]; then
                            echo "[g8e] Failed to create evals user" >&2
                            exit 1
                        fi
                        echo "  Created user with ID: $_user_id"
                    else
                        echo "  Found existing evals user: $_user_id"
                    fi
                    
                    # Create device link for the user
                    echo "  Creating device link for evals user..."
                    _device_token="$(python3 "$SCRIPT_DIR/scripts/data/manage-operator.py" device-links create --user-id "$_user_id" --name "evals-fleet" --max-uses 100 2>/dev/null | grep -E '^  Token:' | awk '{print $2}' || true)"
                    if [[ -z "$_device_token" ]]; then
                        echo "[g8e] Failed to create device link" >&2
                        exit 1
                    fi
                    echo "  Created device link: $_device_token"
                    _auto_created=true
                fi
                
                if [[ -n "$_device_token" ]]; then
                    echo "  Bringing up $_nodes eval nodes with device token..."
                else
                    echo "  Bringing up $_nodes eval nodes (no device token)..."
                fi
                _ca_cert="$(cat "$G8E_SSL_DIR_HOST/ca.crt" 2>/dev/null || true)"
                DEVICE_TOKEN="$_device_token" G8E_CA_CERT="$_ca_cert" COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" up -d --build --scale eval-node="$_nodes"
                echo ""
                echo "  Eval fleet is up. Check status with: ./g8e evals status"
                if [[ "$_auto_created" == true ]]; then
                    echo ""
                    echo "  Auto-created resources:"
                    echo "    User: evals@localhost"
                    echo "    Device Token: $_device_token"
                    echo ""
                    echo "  Run evals with: ./g8e evals run --gold-set benchmark"
                fi
                exit 0 ;;
            down)
                _banner "evals down"
                COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" down
                echo ""
                echo "  Eval fleet is down."
                exit 0 ;;
            status)
                _banner "evals status"
                COMPOSE_PROJECT_NAME=evals docker compose -f "$EVALS_COMPOSE" ps
                exit 0 ;;
            logs)
                _banner "evals logs ${3:-}"
                if [[ -z "${3:-}" ]]; then
                    echo "[g8e] evals logs requires a node name" >&2
                    echo "  Usage: ./g8e evals logs <node-name>" >&2
                    exit 1
                fi
                docker logs -f "${3}"
                exit 0 ;;
            list)
                _banner "evals list"
                _venv="$SCRIPT_DIR/components/g8ee/.venv"
                if [ ! -x "$_venv/bin/python" ]; then
                    echo "[g8e] g8ee virtualenv missing at $_venv — run ./g8e platform start first" >&2
                    exit 1
                fi
                (
                    cd "$SCRIPT_DIR/components/g8ee"
                    export PYTHONPATH="$SCRIPT_DIR/components/g8ee:$SCRIPT_DIR/shared${PYTHONPATH:+:$PYTHONPATH}"
                    export G8E_SHARED_DIR="$SCRIPT_DIR/shared"
                    "$_venv/bin/python" -m app.evals.runner.cli list
                )
                ;;
            *)
                echo "[g8e] unknown evals subcommand: '$SUB'" >&2
                echo "  Valid: run, list, up, down, status, logs" >&2
                exit 1 ;;
        esac ;;

    *)
        echo "[g8e] unknown command: '$TOP'" >&2
        echo "  Run: ./g8e --help" >&2
        exit 1 ;;

esac
