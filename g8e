                    _args=("${_args[@]:2}") ;;
                -a|--assistant-model)
                    _require_value "-a/--assistant-model"
                    export TEST_LLM_ASSISTANT_MODEL="${_args[1]}"
                    _args=("${_args[@]:2}") ;;
