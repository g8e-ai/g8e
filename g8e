    # ------------------------------------------------------------------
    # demo — manages the broken-fleet demo; must run on host
    # ------------------------------------------------------------------
    demo)
        DEMO_DIR="$SCRIPT_DIR/demo"
        PROFILES_DIR="$DEMO_DIR/profiles"
        if [[ ! -d "$DEMO_DIR" ]]; then
            echo "[g8e] demo directory not found: $DEMO_DIR" >&2
            exit 1
        fi

        # Profile management subcommands
        if [[ "$SUB" == "profile" ]]; then
            mkdir -p "$PROFILES_DIR"
            _PROF_CMD="${3:-}"
            _PROF_NAME="${4:-}"
            _ACTIVE_FILE="$PROFILES_DIR/.active"

            # Helper to perform actions on demo/ while excluding profiles/
            _demo_items() {
                find "$DEMO_DIR" -maxdepth 1 -mindepth 1 -name "profiles" -prune -o -print
            }

            case "$_PROF_CMD" in
                list)
                    _banner "demo profile list"
                    _active=$(cat "$_ACTIVE_FILE" 2>/dev/null || echo "default")
                    echo "Available profiles:"
                    echo "  * default (active: $([[ "$_active" == "default" ]] && echo "yes" || echo "no"))"
                    for d in "$PROFILES_DIR"/*/; do
                        [[ -d "$d" ]] || continue
                        p=$(basename "$d")
                        [[ "$p" == ".default_bak" ]] && continue
                        echo "  * $p (active: $([[ "$_active" == "$p" ]] && echo "yes" || echo "no"))"
                    done
                    exit 0 ;;
                create)
                    [[ -z "$_PROF_NAME" ]] && { echo "[g8e] usage: ./g8e demo profile create <name>"; exit 1; }
                    [[ "$_PROF_NAME" == "default" ]] && { echo "[g8e] 'default' is a reserved profile name"; exit 1; }
                    _banner "demo profile create $_PROF_NAME"
                    if [[ -d "$PROFILES_DIR/$_PROF_NAME" ]]; then
                        echo "[g8e] profile '$_PROF_NAME' already exists" >&2
                        exit 1
                    fi
                    mkdir -p "$PROFILES_DIR/$_PROF_NAME"
                    _demo_items | xargs -I {} cp -a {} "$PROFILES_DIR/$_PROF_NAME/"
                    echo "[g8e] profile '$_PROF_NAME' created from current demo/"
                    exit 0 ;;
                switch)
                    _PROF_NAME="${4:-}"
                    [[ -z "$_PROF_NAME" ]] && { echo "[g8e] usage: ./g8e demo profile switch <name>"; exit 1; }
                    _banner "demo profile switch $_PROF_NAME"
                    
                    # Check if any containers in the demo project are running
                    if docker ps --filter "label=com.docker.compose.project=demo" --format '{{.Names}}' | grep -q .; then
                        echo "[g8e] demo containers are currently running. Stop them first: ./g8e demo down" >&2
                        exit 1
                    fi

                    _current_active=$(cat "$_ACTIVE_FILE" 2>/dev/null || echo "default")
                    
                    if [[ "$_PROF_NAME" != "default" && ! -d "$PROFILES_DIR/$_PROF_NAME" ]]; then
                        echo "[g8e] profile '$_PROF_NAME' not found" >&2
                        exit 1
                    fi

                    # Save current demo/ to its profile directory (only if changing profiles)
                    if [[ "$_current_active" != "$_PROF_NAME" ]]; then
                        if [[ "$_current_active" == "default" ]]; then
                            mkdir -p "$PROFILES_DIR/.default_bak"
                            rm -rf "$PROFILES_DIR/.default_bak"/*
                            _demo_items | xargs -I {} cp -a {} "$PROFILES_DIR/.default_bak/"
                        else
                            rm -rf "$PROFILES_DIR/$_current_active"
                            mkdir -p "$PROFILES_DIR/$_current_active"
                            _demo_items | xargs -I {} cp -a {} "$PROFILES_DIR/$_current_active/"
                        fi
                    fi

                    # Swap in the new profile
                    _demo_items | xargs rm -rf
                    if [[ "$_PROF_NAME" == "default" ]]; then
                        cp -a "$PROFILES_DIR/.default_bak"/. "$DEMO_DIR/"
                    else
                        cp -a "$PROFILES_DIR/$_PROF_NAME"/. "$DEMO_DIR/"
                    fi
                    
                    echo "$_PROF_NAME" > "$_ACTIVE_FILE"
                    echo "[g8e] switched to profile: $_PROF_NAME"
                    exit 0 ;;
                delete)
                    [[ -z "$_PROF_NAME" ]] && { echo "[g8e] usage: ./g8e demo profile delete <name>"; exit 1; }
                    [[ "$_PROF_NAME" == "default" ]] && { echo "[g8e] cannot delete default profile"; exit 1; }
                    _active=$(cat "$_ACTIVE_FILE" 2>/dev/null || echo "default")
                    [[ "$_active" == "$_PROF_NAME" ]] && { echo "[g8e] cannot delete active profile"; exit 1; }
                    _banner "demo profile delete $_PROF_NAME"
                    rm -rf "$PROFILES_DIR/$_PROF_NAME"
                    echo "[g8e] profile '$_PROF_NAME' deleted"
                    exit 0 ;;
                *)
                    echo "[g8e] unknown demo profile subcommand: '$_PROF_CMD'" >&2
                    echo "  Valid: list, create, switch, delete" >&2
                    exit 1 ;;
            esac
        fi
        # Parse -d flag for device token shorthand, or use global DEVICE_TOKEN
        # Parse -n flag for node count
        demo_args=("${@:3}")
        device_token=""
        nodes=""
        i=0
        while [[ $i -lt ${#demo_args[@]} ]]; do
            arg="${demo_args[$i]}"
            if [[ "$arg" == "-d" ]]; then
                if [[ $((i + 1)) -lt ${#demo_args[@]} ]]; then
                    device_token="${demo_args[$((i + 1))]}"
                    unset "demo_args[$i]" "demo_args[$((i + 1))]"
                    # Re-index to avoid holes
                    demo_args=("${demo_args[@]}")
                    i=0
                    continue
                else
                    echo "[g8e] -d flag requires a token value" >&2
                    exit 1
                fi
            fi
            i=$((i + 1))
        done
        i=0
        while [[ $i -lt ${#demo_args[@]} ]]; do
            arg="${demo_args[$i]}"
            if [[ "$arg" == "-n" ]]; then
                if [[ $((i + 1)) -lt ${#demo_args[@]} ]]; then
                    nodes="${demo_args[$((i + 1))]}"
                    unset "demo_args[$i]" "demo_args[$((i + 1))]"
                    # Re-index to avoid holes
                    demo_args=("${demo_args[@]}")
                    i=0
                    continue
                else
                    echo "[g8e] -n flag requires a node count value" >&2
                    exit 1
                fi
            fi
            i=$((i + 1))
        done
        # Use global DEVICE_TOKEN if -d not provided
        if [[ -z "$device_token" && -n "$DEVICE_TOKEN" ]]; then
            device_token="$DEVICE_TOKEN"
        fi
        # Convert device_token to DEVICE_TOKEN for make
        if [[ -n "$device_token" ]]; then
            demo_args=("DEVICE_TOKEN=$device_token" "${demo_args[@]}")
        fi
        # Convert nodes to NODES for make (and N for compatibility)
        if [[ -n "$nodes" ]]; then
            demo_args=("NODES=$nodes" "N=$nodes" "${demo_args[@]}")
        fi
        case "$SUB" in
            -h|--help|"")
                help_file="$SCRIPT_DIR/docs/g8e-help.md"
                if [[ -f "$help_file" ]]; then
                    awk '/^### demo/,/^### evals/' "$help_file" | head -n -1
                else
                    echo "[g8e] Help file not found: $help_file" >&2
                    exit 1
                fi
                [[ -z "$SUB" ]] && exit 1 || exit 0
                ;;
            up|down|status|clean|health|nginx-check|operators|logs|deploy|discover-hosts|stream|vanish|dashboard)
                _banner "demo $SUB"
                exec make -C "$DEMO_DIR" "$SUB" "${demo_args[@]}" ;;
            shell)
                _banner "demo shell"
                exec make -C "$DEMO_DIR" shell "${demo_args[@]}" ;;
            *)
                echo "[g8e] unknown demo subcommand: '$SUB'" >&2
                echo "  Valid: up, down, status, clean, health, nginx-check, operators, logs, shell, deploy, discover-hosts, stream, vanish, dashboard" >&2
                exit 1 ;;
        esac ;;

