#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export G8E_PROJECT_ROOT="$SCRIPT_DIR"

# Check for common dependencies
_check_deps() {
    local missing=()
    for cmd in curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "\033[0;31m[g8e] ERROR: Missing required dependencies: ${missing[*]}\033[0m" >&2
        exit 1
    fi
}

_check_deps

# Load environment variables from .g8e/.env if it exists
if [[ -f "$SCRIPT_DIR/.g8e/.env" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" =~ ^export\ [A-Za-z0-9_]+= ]]; then
            eval "$line"
        fi
    done < "$SCRIPT_DIR/.g8e/.env"
fi

DEV_MODE=false
G8E_RUNTIME_DIR="${G8E_RUNTIME_DIR:-$SCRIPT_DIR/.g8e}"
G8E_PKI_DIR_HOST="${G8E_PKI_DIR:-$G8E_RUNTIME_DIR/pki}"
G8E_SECRETS_DIR_HOST="${G8E_SECRETS_DIR:-$G8E_RUNTIME_DIR/secrets}"
OPERATOR_HTTP_URL="${G8E_INTERNAL_HTTP_URL:-https://localhost:9000}"
G8E_CREDENTIALS_DIR="$HOME/.g8e"
G8E_CREDENTIALS_FILE="$G8E_CREDENTIALS_DIR/credentials"

# Source common helpers for the wrapper itself
source "$SCRIPT_DIR/scripts/cmd/common.sh"

_ensure_llm_config() {
    # Check for G8E_ prefixed vars and populate standard ones if found
    if [[ -n "${G8E_TEST_LLM_PROVIDER:-}" ]]; then
        export TEST_LLM_PROVIDER="$G8E_TEST_LLM_PROVIDER"
    fi
    if [[ -n "${G8E_TEST_LLM_API_KEY:-}" ]]; then
        export TEST_LLM_API_KEY="$G8E_TEST_LLM_API_KEY"
    fi
}

_menu() {
    if [[ ! -t 0 ]]; then _help; exit 0; fi
    while true; do
        clear
        echo -e "\033[1;34m  __ _   ___   ___  \033[0m"; echo -e "\033[1;34m / _\` | ( _ ) / _ \\ \033[0m"; echo -e "\033[1;34m| (_| | / _ \\|  __/ \033[0m"; echo -e "\033[1;34m \\__, | \\___/ \\___| \033[0m"; echo -e "\033[1;34m  ___/              \033[0m"
        echo ""; echo -e "\033[1;32m   Interactive g8e Platform Manager\033[0m"; echo ""
        echo "1) Platform Status"; echo "2) Start Platform"; echo "3) Stop Platform"; echo "4) View Logs"; echo "5) Run Tests"; echo "6) Demo Fleet"; echo "7) Evaluation Suite"; echo "8) Environment Variables (vars)"; echo "9) Login / Auth"; echo "10) Advanced (Data/Security/Setup)"; echo "0) Exit"
        echo ""; read -p "Choose an option [0-10]: " choice; echo ""
        case $choice in
            1) ./g8e platform status ;;
            2) ./g8e platform start ;;
            3) ./g8e platform stop ;;
            4) ./g8e platform logs ;;
            5)
                echo "1) g8eo (Go Operator)"; echo "2) g8ee (Python Engine)"
                read -p "Select component [1-2]: " tcomp
                case $tcomp in
                    1) ./g8e test g8eo ;;
                    2) ./g8e test g8ee ;;
                esac ;;
            6)
                echo "1) Up"; echo "2) Status"; echo "3) Down"
                read -p "Select demo action [1-3]: " dact
                case $dact in 1) ./g8e demo up ;; 2) ./g8e demo status ;; 3) ./g8e demo down ;; esac ;;
            7)
                echo "1) Run benchmark"; echo "2) List evals"; echo "3) Status"
                read -p "Select eval action [1-3]: " eact
                case $eact in 1) ./g8e evals run --gold-set benchmark ;; 2) ./g8e evals list ;; 3) ./g8e evals status ;; esac ;;
            8) ./g8e vars list ;;
            9) if _credentials_exist; then echo "Current Session: $OPERATOR_ID"; read -p "Logout? [y/N]: " lout; [[ "$lout" == "y" ]] && ./g8e logout; else ./g8e login; fi ;;
            10)
                echo "1) Security Status"; echo "2) LLM Setup"; echo "3) Search Setup"; echo "4) SSH Setup"
                read -p "Select advanced option [1-4]: " adv
                case $adv in 1) ./g8e security validate ;; 2) ./g8e llm show ;; 3) ./g8e search setup ;; 4) ./g8e ssh setup ;; esac ;;
            0) exit 0 ;;
            *) echo "Invalid option." ;;
        esac
        echo ""; read -p "Press Enter to continue..."
    done
}

if [[ $# -eq 0 ]]; then _menu; exit 0; fi
if [[ "$1" == "--help" || "$1" == "-h" ]]; then _help; exit 0; fi

# Parse global authentication flags
API_KEY=""; DEVICE_TOKEN=""; filtered_args=(); i=1
while [[ $i -le $# ]]; do
    arg="${!i}"
    case "$arg" in
        --api-key|-k)   [[ $i -lt $# ]] && { ((i++)); API_KEY="${!i}"; }; ((i++)) ;;
        --device-token) [[ $i -lt $# ]] && { ((i++)); DEVICE_TOKEN="${!i}"; }; ((i++)) ;;
        --dev)          DEV_MODE=true; ((i++)) ;;
        -*)             filtered_args+=("$arg"); ((i++)) ;;
        *)              while [[ $i -le $# ]]; do filtered_args+=("${!i}"); ((i++)); done; break ;;
    esac
done
set -- "${filtered_args[@]}"
TOP="$1"; SUB="${2:-}"

# Commands that require authentication
OPERATOR_SESSION_ID=""; USER_ID=""; OPERATOR_ID=""
AUTH_REQUIRED_COMMANDS=("security" "data" "mcp")
if [[ " ${AUTH_REQUIRED_COMMANDS[@]} " =~ " ${TOP} " ]]; then
    _ensure_authenticated
fi
if [[ "$TOP" == "operator" && ("$SUB" == "deploy" || "$SUB" == "stream" || "$SUB" == "reauth") ]]; then _ensure_authenticated; fi
if [[ "$TOP" == "platform" && "$SUB" == "settings" ]]; then _ensure_authenticated; fi

# Dispatch to focused scripts
case "$TOP" in
    platform)   exec bash "$SCRIPT_DIR/scripts/cmd/platform.sh" "$SUB" "${@:3}" ;;
    apps)       exec bash "$SCRIPT_DIR/scripts/cmd/apps.sh" "$SUB" "${@:3}" ;;
    operator)   exec bash "$SCRIPT_DIR/scripts/cmd/operator.sh" "$SUB" "${@:3}" ;;
    test)       exec bash "$SCRIPT_DIR/scripts/cmd/tests.sh" "$SUB" "${@:3}" ;;
    evals|demo) exec bash "$SCRIPT_DIR/scripts/cmd/evals_demo.sh" "$TOP" "$SUB" "${@:3}" ;;
    user)       exec bash "$SCRIPT_DIR/scripts/cmd/user.sh" "$SUB" "${@:3}" ;;
    vars|login|logout|ssh|aws|search|llm|security|data|mcp)
                exec bash "$SCRIPT_DIR/scripts/cmd/infra.sh" "$TOP" "$SUB" "${@:3}" ;;
    *)
        echo "[g8e] unknown command: '$TOP'" >&2
        echo "  Run: ./g8e --help" >&2
        exit 1 ;;
esac
