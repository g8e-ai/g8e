{
  "_comment": "Reusable sub-shape definitions referenced by wire/heartbeat.json (os_details, user_details, disk_details, memory_details, environment, fingerprint_details). These are NOT the deleted OperatorDocument.system_info field.",

  "os_details": {
    "type": "object",
    "required": false,
    "description": "Detailed operating system information",
    "fields": {
      "kernel": { "type": "string" },
      "distro": { "type": "string" },
      "version": { "type": "string" }
    }
  },

  "user_details": {
    "type": "object",
    "required": false,
    "description": "Details about the current OS user",
    "fields": {
      "username": { "type": "string" },
      "uid": { "type": "integer" },
      "gid": { "type": "integer" },
      "home": { "type": "string" },
      "name": { "type": "string" },
      "shell": { "type": "string" }
    }
  },

  "disk_details": {
    "type": "object",
    "required": false,
    "description": "Root filesystem disk usage",
    "fields": {
      "total_gb": { "type": "number" },
      "used_gb": { "type": "number" },
      "free_gb": { "type": "number" },
      "percent": { "type": "number" }
    }
  },

  "memory_details": {
    "type": "object",
    "required": false,
    "description": "Detailed memory usage breakdown",
    "fields": {
      "total_mb": { "type": "integer" },
      "available_mb": { "type": "integer" },
      "used_mb": { "type": "integer" },
      "percent": { "type": "number" }
    }
  },

  "environment": {
    "type": "object",
    "required": false,
    "description": "Environment and container context",
    "fields": {
      "pwd": { "type": "string" },
      "lang": { "type": "string" },
      "timezone": { "type": "string" },
      "term": { "type": "string" },
      "is_container": { "type": "boolean" },
      "container_runtime": { "type": "string" },
      "container_signals": { "type": "array", "items": "string" },
      "init_system": { "type": "string" }
    }
  },

  "fingerprint_details": {
    "type": "object",
    "required": false,
    "description": "Structured sub-fields used to compute system_fingerprint",
    "fields": {
      "os": { "type": "string" },
      "architecture": { "type": "string" },
      "cpu_count": { "type": "integer" },
      "machine_id": { "type": "string" }
    }
  }
}
