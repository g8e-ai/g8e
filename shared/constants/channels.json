{
  "_comment": "Canonical pub/sub channel prefixes and KV binding key patterns shared across g8ee (Python), g8eo (Go), and VSOD (JS). Channel format: {prefix}:{operator.id}:{operator.session.id}",

  "pubsub": {
    "separator": ":",
    "segment_count": 3,
    "prefixes": {
      "cmd": "cmd",
      "results": "results",
      "heartbeat": "heartbeat",
      "g8eo_results": "g8eo_results",
      "operator_heartbeats": "operator_heartbeats",
      "sse_events": "sse_events",
      "system_events": "system_events"
    },
    "auth": {
      "publish.prefix": "auth.publish:",
      "publish.session.prefix": "auth.publish:session:",
      "response.prefix": "auth.response:",
      "response.session.prefix": "auth.response:session:",
      "session.prefix": "auth.session:"
    }
  }
}
