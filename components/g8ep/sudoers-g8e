# g8e node sudoers configuration for g8e user (Alpine paths)
# Allows execution of network troubleshooting and system monitoring tools

# Default environment preservation
Defaults:g8e !env_reset, env_keep += "G8E_* G8E_SSL_CERT_FILE"

# Network troubleshooting tools requiring root
g8e ALL=(root) NOPASSWD: /usr/bin/tcpdump
g8e ALL=(root) NOPASSWD: /usr/bin/nmap
g8e ALL=(root) NOPASSWD: /usr/sbin/mtr
g8e ALL=(root) NOPASSWD: /usr/bin/iperf3
g8e ALL=(root) NOPASSWD: /usr/sbin/nethogs
g8e ALL=(root) NOPASSWD: /usr/sbin/iftop
g8e ALL=(root) NOPASSWD: /usr/bin/lsof
g8e ALL=(root) NOPASSWD: /usr/bin/strace

# Network configuration utilities
g8e ALL=(root) NOPASSWD: /sbin/ip
g8e ALL=(root) NOPASSWD: /sbin/route
g8e ALL=(root) NOPASSWD: /sbin/arp
g8e ALL=(root) NOPASSWD: /bin/netstat
g8e ALL=(root) NOPASSWD: /sbin/ss

# System monitoring and debugging
g8e ALL=(root) NOPASSWD: /usr/bin/htop
g8e ALL=(root) NOPASSWD: /bin/ps
g8e ALL=(root) NOPASSWD: /usr/bin/top
g8e ALL=(root) NOPASSWD: /bin/df
g8e ALL=(root) NOPASSWD: /usr/bin/du
g8e ALL=(root) NOPASSWD: /usr/bin/free

# File system operations for troubleshooting
g8e ALL=(root) NOPASSWD: /bin/mount
g8e ALL=(root) NOPASSWD: /bin/umount

# Process management
g8e ALL=(root) NOPASSWD: /bin/kill
g8e ALL=(root) NOPASSWD: /usr/bin/killall
g8e ALL=(root) NOPASSWD: /usr/bin/pkill

# Network interface management
g8e ALL=(root) NOPASSWD: /sbin/ifconfig

# DNS and resolution debugging
g8e ALL=(root) NOPASSWD: /usr/bin/dig
g8e ALL=(root) NOPASSWD: /usr/bin/nslookup
g8e ALL=(root) NOPASSWD: /usr/bin/host

# Log access for troubleshooting
g8e ALL=(root) NOPASSWD: /bin/cat
g8e ALL=(root) NOPASSWD: /usr/bin/tail
g8e ALL=(root) NOPASSWD: /usr/bin/head
g8e ALL=(root) NOPASSWD: /bin/grep
g8e ALL=(root) NOPASSWD: /usr/bin/less
g8e ALL=(root) NOPASSWD: /bin/more

# Hardware information
g8e ALL=(root) NOPASSWD: /bin/dmesg

# Secure shell utilities
g8e ALL=(root) NOPASSWD: /usr/bin/ssh-keygen
g8e ALL=(root) NOPASSWD: /usr/bin/ssh-copy-id

# Archive utilities for data collection
g8e ALL=(root) NOPASSWD: /bin/tar
g8e ALL=(root) NOPASSWD: /bin/gzip
g8e ALL=(root) NOPASSWD: /usr/bin/bzip2
