# g8eo Test Runner & Operator Builder
#
# Lean Go container for running g8eo tests and building operator binaries.
# Uses golang:alpine — the same base as the g8es production builder stage.
# Source code is volume-mounted at runtime — never baked into the image.
#
# Usage (via ./g8e test g8eo):
#   docker compose exec g8eo-test-runner /app/scripts/testing/run_tests.sh g8eo [OPTIONS]
# Operator build (via ./g8e operator build):
#   docker compose exec g8eo-test-runner make -C /app/components/g8eo build

FROM golang:1.26-alpine3.23

RUN set -ex; \
    for i in 1 2 3; do \
        apk add --no-cache \
            bash \
            curl \
            ca-certificates \
            openssl \
            jq \
            git \
            make \
            gcc \
            musl-dev \
            protobuf \
            protoc \
            protobuf-dev \
            python3 \
            py3-pip \
            npm \
            nodejs \
            gcompat \
            libstdc++ \
        && break || \
        { echo "apk add failed, retrying in 5s... ($i/3)"; sleep 5; }; \
    done

ENV GOPATH="/home/g8e/go"
ENV GOBIN="/home/g8e/go/bin"
ENV GOCACHE="/home/g8e/.cache/go"
ENV PATH="/home/g8e/go/bin:${PATH}"

WORKDIR /app

RUN addgroup -g 1001 g8e \
    && adduser -u 1001 -G g8e -D -s /bin/bash g8e

USER g8e

COPY --chown=g8e:g8e components/g8eo/go.mod components/g8eo/go.sum /app/components/g8eo/
COPY --chown=g8e:g8e components/g8eo/vendor/ /app/components/g8eo/vendor/
COPY --chown=g8e:g8e components/g8eo/tools/ /app/components/g8eo/tools/

RUN cd /app/components/g8eo/tools \
    && go build -mod=vendor -o /home/g8e/go/bin/gotestsum gotest.tools/gotestsum

RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest \
    && go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest

USER root
RUN pip3 install --no-cache-dir grpcio-tools --break-system-packages \
    && npm install -g grpc-tools \
    && curl -L https://github.com/grpc/grpc-web/releases/download/1.5.0/protoc-gen-grpc-web-1.5.0-linux-x86_64 -o /usr/local/bin/protoc-gen-grpc-web \
    && chmod +x /usr/local/bin/protoc-gen-grpc-web \
    && curl -L https://github.com/protocolbuffers/protobuf-javascript/releases/download/v3.21.4/protobuf-javascript-3.21.4-linux-x86_64.tar.gz -o /tmp/protobuf-javascript.tar.gz \
    && tar -xvf /tmp/protobuf-javascript.tar.gz -C /usr/local/bin --strip-components=1 bin/protoc-gen-js \
    && rm /tmp/protobuf-javascript.tar.gz
USER g8e
