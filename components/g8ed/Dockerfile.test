# g8ed Test Runner
#
# Lean Node.js container for running g8ed vitest tests.
# Source code is volume-mounted at runtime — never baked into the image.
#
# Usage (via ./g8e test g8ed):
#   docker compose exec g8ed-test-runner /app/scripts/testing/run_tests.sh g8ed [OPTIONS]

FROM node:22-alpine3.23

WORKDIR /app/components/g8ed

RUN set -ex; \
    for i in 1 2 3; do \
        apk add --no-cache \
            curl \
            bash \
            ca-certificates \
            openssl \
            jq \
        && break || \
        { echo "apk add failed, retrying in 5s... ($i/3)"; sleep 5; }; \
    done \
    && addgroup -g 1001 g8e \
    && adduser -u 1001 -G g8e -H -D -s /bin/bash g8e

COPY components/g8ed/package.json components/g8ed/package-lock.json ./
COPY components/g8ed/vitest.config.js /app/g8ed-vitest.config.js

RUN npm config set update-notifier false -g \
    && npm ci \
    && chown -R g8e:g8e /app/components/g8ed

USER g8e

CMD ["sleep", "infinity"]
