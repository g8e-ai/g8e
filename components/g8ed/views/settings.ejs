<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - g8e</title>
    <meta name="robots" content="noindex, nofollow">

    <%- include('partials/head-public') %>

    <link rel="stylesheet" href="/css/settings.css?v=<%= assetVersion %>">
</head>
<body class="settings-body" data-theme="<%= theme %>">
    <%- include('partials/nav-public', { currentPage: 'settings' }) %>

    <main class="settings-page">

        <a href="/chat" class="settings-back-link">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to Chat
        </a>

        <header class="settings-header">
            <div class="settings-header-left">
                <span class="material-symbols-outlined settings-header-icon">tune</span>
                <div>
                    <h1 class="settings-title">Settings</h1>
                    <p class="settings-subtitle">Platform configuration — changes take effect on next service restart</p>
                </div>
            </div>
            <div class="settings-header-actions">
                <button class="settings-save-btn" id="save-btn" disabled>
                    <span class="material-symbols-outlined">save</span>
                    Save Changes
                </button>
            </div>
        </header>

        <div class="settings-status" id="status-bar">
            <span class="material-symbols-outlined" id="status-icon"></span>
            <span id="status-msg"></span>
        </div>

        <div id="settings-loading" class="settings-loading">
            <span class="material-symbols-outlined spin">sync</span>
            Loading settings...
        </div>

        <div id="settings-body" style="display:none;">
            <div class="settings-layout">
                <!-- Section nav -->
                <nav class="settings-nav" id="settings-nav"></nav>

                <!-- Section content -->
                <div id="settings-sections"></div>
            </div>

            <!-- Advanced / Dev Panel (Moved from top banner to be managed by JS sections) -->
            <template id="advanced-section-template">
                <div class="settings-field">
                    <div class="settings-field-label">Dev Logging</div>
                    <div class="settings-field-desc">Enable verbose browser console output for this account. Only visible to admin and superadmin users. Takes effect immediately on next page load.</div>
                    <label class="settings-toggle">
                        <input type="checkbox" id="dev-logs-toggle">
                        <span class="settings-toggle-track">
                            <span class="settings-toggle-thumb"></span>
                        </span>
                        <span class="settings-toggle-label" id="dev-logs-label">Disabled</span>
                    </label>
                </div>
            </template>

            <div class="settings-restart-notice">
                <span class="material-symbols-outlined">info</span>
                <span>Settings saved here are stored in the platform database and will take effect on next container restart. Environment variables set in the <code>docker-compose.yml</code> <code>environment:</code> block always take precedence and the corresponding fields are read-only here.</span>
            </div>
        </div>

    </main>

    <%- include('partials/footer-public') %>

    <script id="llm-catalog" type="application/json"><%- JSON.stringify(llmCatalog).replace(/</g, '\u003c') %></script>
    <script type="module" src="/js/components/hamburger-menu.js"></script>
    <script type="module" nonce="<%= cspNonce %>">
        import { SettingsPage } from '/js/components/settings-page.js';
        const page = new SettingsPage();
        page.init();
    </script>
</body>
</html>
