<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="g8e - Platform Setup">
    <meta name="robots" content="noindex, nofollow">
    <title>g8e - Platform Setup</title>

    <%- include('partials/head-public') %>

    <link rel="stylesheet" href="/css/setup.css?v=<%= assetVersion %>">
</head>

<body data-theme="<%= theme %>">
    <%- include('partials/nav-public', { currentPage: 'setup' }) %>

    <main class="setup-page">
        <div class="setup-container">

            <!-- ================================================================
                 Step indicator
                 ================================================================ -->
            <div class="wizard-steps-wrap">
            <nav class="wizard-steps" aria-label="Setup progress">
                <div class="wizard-step active" data-step="1">
                    <div class="wizard-step-circle">
                        <span class="wizard-step-num">1</span>
                        <span class="wizard-step-check material-symbols-outlined">check</span>
                    </div>
                    <span class="wizard-step-label">Configure</span>
                </div>
                <div class="wizard-step-connector"></div>
                <div class="wizard-step" data-step="2">
                    <div class="wizard-step-circle">
                        <span class="wizard-step-num">2</span>
                        <span class="wizard-step-check material-symbols-outlined">check</span>
                    </div>
                    <span class="wizard-step-label">Finish</span>
                </div>
            </nav>
            </div>

            <!-- Status bar -->
            <div class="setup-status" id="setup-status">
                <span class="material-symbols-outlined" id="setup-status-icon"></span>
                <span id="setup-status-msg"></span>
            </div>

            <!-- ================================================================
                 Step 1: Configure (AI Providers, Web Search)
                 ================================================================ -->
            <div class="wizard-panel active" data-panel="1">
                <!-- AI Providers Section -->
                <div class="wizard-panel-header">
                    <span class="material-symbols-outlined wizard-panel-icon">key</span>
                    <div>
                        <h2 class="wizard-panel-title">AI Providers and Models</h2>
                    </div>
                </div>
                <div class="setup-fields">
                    <div class="setup-fields-row setup-fields-row-api-keys">
                    
                    <!-- Unified model selection -->
                    <div class="setup-fields-model-selection">
                        <div class="wizard-model-selection" id="wizard-model-selection">
                        <div class="wizard-model-fields">
                            <div class="setup-field">
                                <label class="setup-label" for="primary_model">Primary Model</label>
                                <div id="primary_model" class="llm-model-dropdown custom-dropdown setup-model-dropdown" tabindex="0" role="combobox" aria-expanded="false">
                                    <div class="llm-model-dropdown__selected">
                                        <span class="llm-model-icon material-symbols-outlined">model_training</span>
                                        <span class="llm-model-dropdown__text">Select a Model</span>
                                        <span class="llm-model-dropdown__recommended-badge" style="display: none; background: var(--accent-blue); color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px; margin-left: 8px; font-weight: 600; text-transform: uppercase;">Recommended</span>
                                        <span class="llm-model-dropdown__arrow material-symbols-outlined">expand_more</span>
                                    </div>
                                    <div class="llm-model-dropdown__menu" id="primary_model-menu"></div>
                                </div>
                            </div>
                            <div class="setup-field">
                                <label class="setup-label" for="assistant_model">Assistant Model</label>
                                <div id="assistant_model" class="llm-model-dropdown custom-dropdown setup-model-dropdown" tabindex="0" role="combobox" aria-expanded="false">
                                    <div class="llm-model-dropdown__selected">
                                        <span class="llm-model-icon material-symbols-outlined">psychology</span>
                                        <span class="llm-model-dropdown__text">Select a Model</span>
                                        <span class="llm-model-dropdown__recommended-badge" style="display: none; background: var(--accent-blue); color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px; margin-left: 8px; font-weight: 600; text-transform: uppercase;">Recommended</span>
                                        <span class="llm-model-dropdown__arrow material-symbols-outlined">expand_more</span>
                                    </div>
                                    <div class="llm-model-dropdown__menu" id="assistant_model-menu"></div>
                                </div>
                            </div>
                            <div class="setup-field">
                                <label class="setup-label" for="lite_model">Lite Model</label>
                                <div id="lite_model" class="llm-model-dropdown custom-dropdown setup-model-dropdown" tabindex="0" role="combobox" aria-expanded="false">
                                    <div class="llm-model-dropdown__selected">
                                        <span class="llm-model-icon material-symbols-outlined">bolt</span>
                                        <span class="llm-model-dropdown__text">Select a Model</span>
                                        <span class="llm-model-dropdown__recommended-badge" style="display: none; background: var(--accent-blue); color: white; font-size: 10px; padding: 2px 6px; border-radius: 10px; margin-left: 8px; font-weight: 600; text-transform: uppercase;">Recommended</span>
                                        <span class="llm-model-dropdown__arrow material-symbols-outlined">expand_more</span>
                                    </div>
                                    <div class="llm-model-dropdown__menu" id="lite_model-menu"></div>
                                </div>
                            </div>
                        </div>
                        </div>
                    </div>

                        <div class="setup-fields-api-keys">
                            <!-- Gemini API Key -->
                            <div class="wizard-provider-key-row" data-provider="gemini">
                        <div class="wizard-provider-key-header">
                            <span class="material-symbols-outlined wizard-provider-key-icon">auto_awesome</span>
                            <strong>Gemini</strong>
                            <span class="wizard-provider-key-sub">Google</span>
                            <span class="wizard-provider-key-status" id="status-gemini"></span>
                        </div>
                        <div class="setup-field">
                            <div class="setup-input-wrap">
                                <input type="password" id="gemini_api_key" name="gemini_api_key" class="setup-input has-toggle" placeholder="AIza..." autocomplete="new-password" spellcheck="false">
                                <button type="button" class="setup-reveal-btn" aria-label="Toggle visibility" data-for="gemini_api_key">
                                    <span class="material-symbols-outlined">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Anthropic API Key -->
                    <div class="wizard-provider-key-row" data-provider="anthropic">
                        <div class="wizard-provider-key-header">
                            <span class="material-symbols-outlined wizard-provider-key-icon">smart_toy</span>
                            <strong>Claude</strong>
                            <span class="wizard-provider-key-sub">Anthropic</span>
                            <span class="wizard-provider-key-status" id="status-anthropic"></span>
                        </div>
                        <div class="setup-field">
                            <div class="setup-input-wrap">
                                <input type="password" id="anthropic_api_key" name="anthropic_api_key" class="setup-input has-toggle" placeholder="sk-ant-..." autocomplete="new-password" spellcheck="false">
                                <button type="button" class="setup-reveal-btn" aria-label="Toggle visibility" data-for="anthropic_api_key">
                                    <span class="material-symbols-outlined">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- OpenAI API Key -->
                    <div class="wizard-provider-key-row" data-provider="openai">
                        <div class="wizard-provider-key-header">
                            <span class="material-symbols-outlined wizard-provider-key-icon">hub</span>
                            <strong>GPT</strong>
                            <span class="wizard-provider-key-sub">OpenAI</span>
                            <span class="wizard-provider-key-status" id="status-openai"></span>
                        </div>
                        <div class="setup-field">
                            <div class="setup-input-wrap">
                                <input type="password" id="openai_api_key" name="openai_api_key" class="setup-input has-toggle" placeholder="sk-..." autocomplete="new-password" spellcheck="false">
                                <button type="button" class="setup-reveal-btn" aria-label="Toggle visibility" data-for="openai_api_key">
                                    <span class="material-symbols-outlined">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Ollama Endpoint -->
                    <div class="wizard-provider-key-row" data-provider="ollama">
                        <div class="wizard-provider-key-header">
                            <span class="material-symbols-outlined wizard-provider-key-icon">lan</span>
                            <strong>Ollama</strong>
                            <span class="wizard-provider-key-sub">Self-Hosted</span>
                            <span class="wizard-provider-key-status" id="status-ollama"></span>
                        </div>
                        <div class="setup-field">
                            <input type="text" id="ollama_url" name="ollama_url" class="setup-input" placeholder="192.168.1.100:11434" spellcheck="false" autocomplete="off">
                        </div>
                    </div>
                    </div>
                    </div>

                </div>

                <!-- Web Search Section -->
                <div class="wizard-panel-header">
                    <span class="material-symbols-outlined wizard-panel-icon">travel_explore</span>
                    <div>
                        <h2 class="wizard-panel-title">Web Search</h2>
                    </div>
                </div>
                <div class="setup-fields">
                    <div class="setup-field">
                        <label class="setup-label" for="search_provider">Search Provider</label>
                        <select id="search_provider" class="setup-select">
                            <option value="">None (disable web search)</option>
                            <option value="google">Google</option>
                        </select>
                    </div>
                    <div class="setup-field setup-field-hidden" id="search-config-google">
                        <div class="setup-field">
                            <label class="setup-label" for="google_project_id">Google Project ID</label>
                            <input type="text" id="google_project_id" name="google_project_id" class="setup-input" placeholder="your-project-id" spellcheck="false" autocomplete="off">
                        </div>
                        <div class="setup-field">
                            <label class="setup-label" for="vertex_ai_search_app_id">Vertex AI Search App ID</label>
                            <input type="text" id="vertex_ai_search_app_id" name="vertex_ai_search_app_id" class="setup-input" placeholder="your-app-id" spellcheck="false" autocomplete="off">
                        </div>
                        <div class="setup-field">
                            <label class="setup-label" for="search_api_key">
                                API Key
                                <a href="https://aistudio.google.com/app/api_keys" target="_blank" rel="noopener noreferrer" class="setup-label-link" id="search-api-key-link">
                                    <span class="material-symbols-outlined">open_in_new</span>Get key
                                </a>
                            </label>
                            <label class="setup-checkbox-label setup-field-hidden" id="use-gemini-key-wrap" for="use_gemini_api_key">
                                <input type="checkbox" id="use_gemini_api_key" name="use_gemini_api_key" class="setup-checkbox">
                                <span>Use Gemini API Key</span>
                            </label>
                            <div class="setup-input-wrap">
                                <input type="password" id="search_api_key" name="search_api_key" class="setup-input has-toggle" placeholder="AIza..." autocomplete="new-password" spellcheck="false">
                                <button type="button" class="setup-reveal-btn" aria-label="Toggle visibility" data-for="search_api_key">
                                    <span class="material-symbols-outlined">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================================================================
                 Step 2: Finish
                 ================================================================ -->
            <div class="wizard-panel" data-panel="2">
                <div class="wizard-panel-header">
                    <span class="material-symbols-outlined wizard-panel-icon">check_circle</span>
                    <div>
                        <h2 class="wizard-panel-title">Almost Done</h2>
                    </div>
                </div>

                <!-- Summary card -->
                <div class="wizard-summary" id="wizard-summary"></div>

                <!-- Finish button -->
                <div class="wizard-finish-actions">
                    <button type="button" id="finish-btn" class="setup-btn-primary setup-btn-lg">
                        <span class="material-symbols-outlined">fingerprint</span>
                        Create Account &amp; Register Passkey
                    </button>
                    <p class="wizard-finish-note">Your browser will prompt you to register a passkey.</p>
                </div>
            </div>

            <!-- ================================================================
                 Wizard navigation
                 ================================================================ -->
            <div class="wizard-nav" id="wizard-nav">
                <button type="button" id="wizard-back-btn" class="setup-btn-secondary">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back
                </button>
                <button type="button" id="wizard-next-btn" class="setup-btn-primary">
                    Next
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>

            </div>
        </main>

    <%- include('partials/footer-public') %>

    <script id="llm-catalog" type="application/json"><%- JSON.stringify(llmCatalog).replace(/</g, '\u003c') %></script>
    <script type="module" src="/js/components/hamburger-menu.js"></script>
    <script type="module" src="/js/components/setup-page.js"></script>
</body>
</html>
