{
    "enabled": false,
    "version": "1.0.0",
    "description": "Command whitelist for Operator execution - DISABLED BY DEFAULT. Enable via config when ready for per-operator assignment.",
    "enforcement_policy": {
        "description": "When enabled, this whitelist defines commands and options permitted for Operator command execution. Currently disabled to allow full flexibility during development.",
        "restrictions": [
            "GeminiAI must only use commands listed in the 'commands' section",
            "GeminiAI must only use options listed in 'safe_options' for each command",
            "GeminiAI must validate all parameters against the 'validation' rules",
            "GeminiAI must respect all 'global_restrictions' and 'forbidden_patterns'",
            "No command execution is permitted outside of this whitelist"
        ]
    },
    "commands": {
        "network_diagnostics": {
            "ping": {
                "description": "Test network connectivity to a host",
                "command": "ping",
                "platforms": [
                    "linux",
                    "windows",
                    "macos"
                ],
                "safe_options": {
                    "linux": [
                        "-c <count>",
                        "-W <timeout>",
                        "-s <size>",
                        "-i <interval>",
                        "-4",
                        "-6"
                    ],
                    "windows": [
                        "-n <count>",
                        "-w <timeout>",
                        "-l <size>",
                        "-4",
                        "-6"
                    ]
                },
                "validation": {
                    "target": "^[a-zA-Z0-9.-]+$",
                    "count": "^[1-9][0-9]?$|^100$",
                    "timeout": "^[1-9]$|^[1-2][0-9]$|^30$",
                    "size": "^[1-9][0-9]{0,3}$|^1[0-3][0-9]{2}$|^1400$"
                },
                "examples": [
                    "ping -c 4 google.com",
                    "ping -c 10 -W 5 192.168.1.1"
                ],
                "max_execution_time": 60
            },
            "traceroute": {
                "description": "Trace the route packets take to reach a host",
                "command": "traceroute",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "windows_equivalent": "tracert",
                "safe_options": {
                    "linux": [
                        "-m <max_hops>",
                        "-w <timeout>",
                        "-q <nqueries>",
                        "-n",
                        "-4",
                        "-6"
                    ],
                    "windows": [
                        "-h <max_hops>",
                        "-w <timeout>",
                        "-d",
                        "-4",
                        "-6"
                    ]
                },
                "validation": {
                    "target": "^[a-zA-Z0-9.-]+$",
                    "max_hops": "^[1-9]$|^[1-2][0-9]$|^30$",
                    "timeout": "^[1-9]$|^10$"
                },
                "examples": [
                    "traceroute google.com",
                    "traceroute -n -m 15 8.8.8.8"
                ],
                "max_execution_time": 180
            },
            "nslookup": {
                "description": "Query DNS servers for domain information",
                "command": "nslookup",
                "platforms": [
                    "linux",
                    "windows",
                    "macos"
                ],
                "safe_options": [
                    "-type=A",
                    "-type=AAAA",
                    "-type=MX",
                    "-type=TXT",
                    "-type=NS",
                    "-type=SOA",
                    "-type=PTR",
                    "-type=CNAME"
                ],
                "validation": {
                    "domain": "^[a-zA-Z0-9.-]+$",
                    "server": "^[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}$"
                },
                "examples": [
                    "nslookup google.com",
                    "nslookup -type=MX example.com",
                    "nslookup example.com 8.8.8.8"
                ],
                "max_execution_time": 30
            },
            "dig": {
                "description": "DNS lookup utility (Linux/macOS)",
                "command": "dig",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "+short",
                    "+trace",
                    "@<server>",
                    "-t <type>",
                    "-x <ip>",
                    "+tcp"
                ],
                "validation": {
                    "domain": "^[a-zA-Z0-9.-]+$",
                    "type": "^(A|AAAA|MX|TXT|NS|SOA|PTR|CNAME|ANY)$",
                    "server": "^[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}$"
                },
                "examples": [
                    "dig google.com",
                    "dig +short MX example.com",
                    "dig @8.8.8.8 example.com"
                ],
                "max_execution_time": 30
            },
            "netstat": {
                "description": "Display network connections and statistics",
                "command": "netstat",
                "platforms": [
                    "linux",
                    "windows",
                    "macos"
                ],
                "safe_options": {
                    "linux": [
                        "-tuln",
                        "-an",
                        "-rn",
                        "-i",
                        "-s"
                    ],
                    "windows": [
                        "-an",
                        "-r",
                        "-s",
                        "-p TCP",
                        "-p UDP"
                    ]
                },
                "examples": [
                    "netstat -tuln",
                    "netstat -an | grep LISTEN",
                    "netstat -rn"
                ],
                "max_execution_time": 10
            },
            "ss": {
                "description": "Modern socket statistics (Linux)",
                "command": "ss",
                "platforms": [
                    "linux"
                ],
                "safe_options": [
                    "-tuln",
                    "-a",
                    "-n",
                    "-p",
                    "-s",
                    "-o"
                ],
                "examples": [
                    "ss -tuln",
                    "ss -an state established",
                    "ss -s"
                ],
                "max_execution_time": 10
            },
            "curl": {
                "description": "Test HTTP/HTTPS connectivity",
                "command": "curl",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "-I",
                    "-v",
                    "-o /dev/null",
                    "--connect-timeout <sec>",
                    "--max-time <sec>",
                    "-k",
                    "-4",
                    "-6",
                    "-w <format>"
                ],
                "validation": {
                    "url": "^https?://[a-zA-Z0-9.-]+(:[0-9]+)?(/.*)?$",
                    "timeout": "^[1-9]$|^[1-5][0-9]$|^60$"
                },
                "examples": [
                    "curl -I https://www.google.com",
                    "curl -v --connect-timeout 5 https://api.example.com/health",
                    "curl -w '\\n%{http_code}\\n' -o /dev/null -s https://example.com"
                ],
                "max_execution_time": 60
            },
            "wget": {
                "description": "Network downloader (test connectivity)",
                "command": "wget",
                "platforms": [
                    "linux"
                ],
                "safe_options": [
                    "--spider",
                    "-t <tries>",
                    "-T <timeout>",
                    "-O /dev/null",
                    "--no-check-certificate"
                ],
                "validation": {
                    "url": "^https?://[a-zA-Z0-9.-]+(:[0-9]+)?(/.*)?$",
                    "tries": "^[1-3]$",
                    "timeout": "^[1-9]$|^[1-2][0-9]$|^30$"
                },
                "examples": [
                    "wget --spider https://www.google.com",
                    "wget -t 2 -T 10 --spider https://example.com"
                ],
                "max_execution_time": 60
            },
            "nc": {
                "description": "Netcat - test port connectivity",
                "command": "nc",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "-v",
                    "-z",
                    "-w <timeout>",
                    "-n",
                    "-u"
                ],
                "validation": {
                    "host": "^[a-zA-Z0-9.-]+$",
                    "port": "^[1-9][0-9]{0,4}$",
                    "timeout": "^[1-9]$|^[1-2][0-9]$|^30$"
                },
                "examples": [
                    "nc -vz google.com 443",
                    "nc -vz -w 5 192.168.1.1 22",
                    "nc -vzu 192.168.1.1 53"
                ],
                "max_execution_time": 30
            },
            "telnet": {
                "description": "Test TCP port connectivity",
                "command": "telnet",
                "platforms": [
                    "linux",
                    "windows",
                    "macos"
                ],
                "safe_usage": "timeout 10 telnet <host> <port>",
                "validation": {
                    "host": "^[a-zA-Z0-9.-]+$",
                    "port": "^[1-9][0-9]{0,4}$"
                },
                "examples": [
                    "timeout 10 telnet google.com 443",
                    "timeout 10 telnet 192.168.1.1 22"
                ],
                "max_execution_time": 10
            },
            "host": {
                "description": "DNS lookup utility",
                "command": "host",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "-t <type>",
                    "-a",
                    "-4",
                    "-6"
                ],
                "validation": {
                    "domain": "^[a-zA-Z0-9.-]+$",
                    "type": "^(A|AAAA|MX|TXT|NS|SOA|PTR|CNAME)$"
                },
                "examples": [
                    "host google.com",
                    "host -t MX example.com"
                ],
                "max_execution_time": 30
            },
            "arp": {
                "description": "Display ARP table",
                "command": "arp",
                "platforms": [
                    "linux",
                    "windows",
                    "macos"
                ],
                "safe_options": {
                    "linux": [
