                    "-type <type>",
                    "-size <size>",
                    "-mtime <days>",
                    "-maxdepth <depth>",
                    "-ls"
                ],
                "validation": {
                    "path": "^[/a-zA-Z0-9._-]+$",
                    "pattern": "^[\"'a-zA-Z0-9.*_-]+[\"']?$",
                    "type": "^[fdl]$",
                    "depth": "^[1-5]$"
                },
                "allowed_paths": [
                    "/var/log",
                    "/tmp",
                    "/etc"
                ],
                "examples": [
