                    "-n",
                    "-c",
                    "-v",
                    "-E",
                    "-F",
                    "-r",
                    "-l",
                    "-L"
                ],
                "validation": {
                    "pattern": "^[a-zA-Z0-9 ._-]+$",
                    "path": "^[/a-zA-Z0-9._-]+$"
                },
                "allowed_paths": [
                    "/var/log",
                    "/etc"
                ],
                "examples": [
                    "grep -i error /var/log/syslog",
                    "grep -n 'connection refused' /var/log/messages",
                    "grep -c ERROR /var/log/*.log"
                ],
                "max_execution_time": 30
            },
            "find": {
                "description": "Search for files and directories",
                "command": "find",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
