                    "cat /etc/hosts",
                    "cat /var/log/syslog | tail -100"
                ],
                "max_execution_time": 10
            },
            "tail": {
                "description": "Display last lines of file",
                "command": "tail",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "-n <lines>",
                    "-f",
                    "-F"
                ],
                "validation": {
                    "lines": "^[1-9][0-9]{0,2}$|^1000$",
                    "path": "^[/a-zA-Z0-9._-]+$"
                },
                "allowed_paths": [
                    "/var/log"
                ],
                "examples": [
                    "tail -n 50 /var/log/syslog",
                    "timeout 30 tail -f /var/log/messages"
                ],
                "max_execution_time": 30
            },
            "head": {
                "description": "Display first lines of file",
                "command": "head",
                "platforms": [
                    "linux",
                    "macos"
                ],
                "safe_options": [
                    "-n <lines>",
                    "-c <bytes>"
                ],
                "validation": {
                    "lines": "^[1-9][0-9]{0,2}$|^1000$",
                    "bytes": "^[1-9][0-9]{0,6}$",
                    "path": "^[/a-zA-Z0-9._-]+$"
                },
                "allowed_paths": [
                    "/var/log",
                    "/etc",
                    "/proc"
                ],
                "examples": [
